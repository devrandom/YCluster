#!/bin/bash
# Launch vLLM serving MiniMax-M2.7 on workstation Blackwell (RTX PRO 6000, SM 12.0).
#
# Usage:
#   ./go-vllm-m27 [--debug] fp8            # MiniMaxAI/MiniMax-M2.7 fp8, TP=4
#   ./go-vllm-m27 [--debug] nvfp4          # nvidia/MiniMax-M2.7-NVFP4, TP=4
#   ./go-vllm-m27 [--debug] nvfp4-tp2      # nvidia/MiniMax-M2.7-NVFP4, TP=2 (2 GPUs free)
#
# --debug    enables VLLM_LOGGING_LEVEL=DEBUG and NCCL_DEBUG=INFO.
# --download fetches weights via `hf download` and exits without starting vLLM.

usage() {
  sed -n '2,/^$/p' "$0" | sed 's/^# \?//'
}

DEBUG=0
DOWNLOAD=0
ARGS=()
for a in "$@"; do
  case "$a" in
    --debug)    DEBUG=1 ;;
    --download) DOWNLOAD=1 ;;
    *) ARGS+=("$a") ;;
  esac
done
set -- "${ARGS[@]}"

case "${1:-}" in
  -h|--help|"") usage; exit 0 ;;
  fp8|nvfp4|nvfp4-tp4|nvfp4-tp2) ;;
  *) usage >&2; exit 2 ;;
esac

set -m
. env.sh

LOG="$(dirname "$0")/vllm-$1.log"
exec > >(tee -a "$LOG") 2>&1
echo "=== $(date -Is) starting $1 ==="

case "${1:-}" in
  fp8)
    MODEL=MiniMaxAI/MiniMax-M2.7
    REASONING=minimax_m2
    TP=4
    EXTRA=()
    ;;
  nvfp4|nvfp4-tp4)
    MODEL=nvidia/MiniMax-M2.7-NVFP4
    REASONING=minimax_m2_append_think
    TP=4
    EXTRA=(--disable-custom-all-reduce)
    ;;
  nvfp4-tp2)
    MODEL=nvidia/MiniMax-M2.7-NVFP4
    REASONING=minimax_m2_append_think
    TP=2
    EXTRA=(--disable-custom-all-reduce)
    ;;
esac

if (( DOWNLOAD )); then
  echo "downloading $MODEL via hf"
  exec env HF_HUB_ENABLE_HF_TRANSFER=1 hf download "$MODEL"
fi

# NVFP4-only env. Setting VLLM_USE_FLASHINFER_MOE_FP4=0 forces VLLM_CUTLASS,
# which deadlocks during autotune on SM 12.0 (vllm#39625) — leave unset so a
# FlashInfer MoE backend is auto-selected.
if [[ "$MODEL" == *NVFP4 ]]; then
  export VLLM_NVFP4_GEMM_BACKEND=flashinfer-cutlass
  export SAFETENSORS_FAST_GPU=1
fi

# Workstation cards have no NVLink between them; force shared-memory NCCL.
export NCCL_P2P_DISABLE=1
export NCCL_DEBUG=WARN
# Cap parallel JIT compile workers — default is nproc, which OOMs CPU RAM.
export TORCHINDUCTOR_COMPILE_THREADS=8
export MAX_JOBS=8

if (( DEBUG )); then
  export VLLM_LOGGING_LEVEL=DEBUG
  export NCCL_DEBUG=INFO
fi

vllm serve "$MODEL" \
  --served-model-name "${MODEL}${SERVED_NAME_SUFFIX:-}" \
  --tensor-parallel-size "$TP" \
  --gpu-memory-utilization 0.95 \
  --trust-remote-code \
  --tool-call-parser minimax_m2 \
  --reasoning-parser "$REASONING" \
  --enable-auto-tool-choice \
  --max-logprobs 1000 \
  --host 0.0.0.0 \
  "${EXTRA[@]}" &
PID=$!
# vLLM workers ignore SIGTERM, so escalate to SIGKILL after a brief grace period.
trap 'kill -TERM -- -$PID 2>/dev/null; sleep 3; kill -KILL -- -$PID 2>/dev/null; wait' INT TERM
wait $PID
