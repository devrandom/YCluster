#!/usr/bin/env python3
"""Stream stdin through, showing the first and last N lines and eliding the middle.

Head lines are printed live as they arrive. Once lines actually start falling out
of the tail buffer, an opening "..." marker is emitted immediately, so a
long-running command shows:

    <first N lines, live>
    ...
    [<count> lines]
    ...
    <last N lines, at EOF>

The "[<count> lines]" and closing "..." can only appear at EOF, since the count
and the identity of the last N lines aren't known until the stream ends.

With -l/--log FILE, the complete un-elided input is teed to FILE (flushed per
line) so it can be followed in detail, e.g. with `tail -f`.
"""

import argparse
import sys
from collections import deque


def main():
    p = argparse.ArgumentParser(
        description="Show the first and last N lines of stdin, eliding the middle.")
    p.add_argument("-n", type=int, default=20, metavar="N",
                   help="lines to show at each end (default: 20)")
    p.add_argument("-H", "--head", type=int, metavar="N",
                   help="head lines to show (overrides -n)")
    p.add_argument("-T", "--tail", type=int, metavar="N",
                   help="tail lines to show (overrides -n)")
    p.add_argument("-l", "--log", metavar="FILE",
                   help="tee the full, un-elided input to FILE")
    args = p.parse_args()

    head = args.head if args.head is not None else args.n
    tail = args.tail if args.tail is not None else args.n

    out = sys.stdout
    log = open(args.log, "w") if args.log else None
    buf = deque(maxlen=tail) if tail > 0 else None
    elided = 0
    opened = False
    seen = 0

    try:
        for line in iter(sys.stdin.readline, ""):
            if log:
                log.write(line)
                log.flush()
            if seen < head:
                out.write(line)
                out.flush()
                seen += 1
                continue
            # Past the head: feed the tail buffer, counting genuine evictions.
            if buf is None:
                elided += 1
            else:
                if len(buf) == tail:  # this append will push one out
                    elided += 1
                buf.append(line)
            if elided and not opened:
                out.write("...\n")
                out.flush()
                opened = True

        if elided:
            out.write("[%d lines]\n...\n" % elided)
        if buf:
            out.writelines(buf)
        out.flush()
    except BrokenPipeError:
        sys.exit(0)
    except KeyboardInterrupt:
        sys.exit(130)
    finally:
        if log:
            log.close()


if __name__ == "__main__":
    main()
