groups:
  - name: ycluster-core
    rules:
      # Node availability
      - alert: NodeDown
        expr: up{job="node-exporter"} == 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "Node {{ $labels.node }} is down"
          description: "Node {{ $labels.node }} has been down for more than 1 minute"

      # YCluster health API
      - alert: YClusterHealthAPIDown
        expr: up{job="ycluster-health"} == 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "YCluster health API down on {{ $labels.node }}"
          description: "YCluster health API on {{ $labels.node }} has been down for more than 2 minutes"


      # Multiple DHCP servers (split brain)
      - alert: MultipleDHCPServers
        expr: count(up{job="ycluster-dhcp"} == 1) > 1
        for: 30s
        labels:
          severity: warning
        annotations:
          summary: "Multiple DHCP servers detected"
          description: "{{ $value }} DHCP servers are running - possible split brain condition"

      # No DHCP servers (handles missing metrics)
      - alert: NoDHCPServers
        expr: absent(up{job="ycluster-dhcp"} == 1) or count(up{job="ycluster-dhcp"} == 1) == 0
        for: 1m
        labels:
          severity: warning
        annotations:
          summary: "No DHCP servers running"
          description: "No DHCP servers are responding in the cluster"

      # High CPU usage
      - alert: HighCPUUsage
        expr: 100 - (avg by(node) (irate(node_cpu_seconds_total{mode="idle"}[5m])) * 100) > 80
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "High CPU usage on {{ $labels.node }}"
          description: "CPU usage on {{ $labels.node }} is above 80% for more than 5 minutes"

      # High memory usage
      - alert: HighMemoryUsage
        expr: (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100 > 85
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "High memory usage on {{ $labels.node }}"
          description: "Memory usage on {{ $labels.node }} is above 85% for more than 5 minutes"

      # Low disk space
      - alert: LowDiskSpace
        expr: (1 - (node_filesystem_avail_bytes{mountpoint="/"} / node_filesystem_size_bytes{mountpoint="/"})) * 100 > 85
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Low disk space on {{ $labels.node }}"
          description: "Disk usage on {{ $labels.node }} root filesystem is above 85%"

      # Critical disk space
      - alert: CriticalDiskSpace
        expr: (1 - (node_filesystem_avail_bytes{mountpoint="/"} / node_filesystem_size_bytes{mountpoint="/"})) * 100 > 95
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "Critical disk space on {{ $labels.node }}"
          description: "Disk usage on {{ $labels.node }} root filesystem is above 95%"

      # Load average
      - alert: HighLoadAverage
        expr: node_load15 / count by(node) (node_cpu_seconds_total{mode="idle"}) > 2
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "High load average on {{ $labels.node }}"
          description: "Load average on {{ $labels.node }} is {{ $value }} (normalized by CPU count) for more than 10 minutes"

      # High external network ingress bandwidth (10GB/hr = ~22.2 Mbps)
      - alert: HighNetworkIngress
        expr: rate(node_network_receive_bytes_total{device="enp87s0"}[5m]) * 8 > 22222222
        for: 1m
        labels:
          severity: warning
        annotations:
          summary: "High external network ingress on {{ $labels.node }}"
          description: "External network ingress on {{ $labels.node }} interface {{ $labels.device }} is {{ $value | humanize }}bps (>10GB/hr) for more than 2 minutes"

      # High external network egress bandwidth (1GB/hr = ~2.2 Mbps)
      - alert: HighNetworkEgress
        expr: rate(node_network_transmit_bytes_total{device="enp87s0"}[5m]) * 8 > 2222222
        for: 1m
        labels:
          severity: warning
        annotations:
          summary: "High external network egress on {{ $labels.node }}"
          description: "External network egress on {{ $labels.node }} interface {{ $labels.device }} is {{ $value | humanize }}bps (>1GB/hr) for more than 2 minutes"

      # Critical external network ingress bandwidth
      - alert: CriticalNetworkIngress
        expr: rate(node_network_receive_bytes_total{device="enp87s0"}[5m]) * 8 > 800000000
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "Critical external network ingress on {{ $labels.node }}"
          description: "External network ingress on {{ $labels.node }} interface {{ $labels.device }} is {{ $value | humanize }}bps - approaching gigabit limit"

      # Critical external network egress bandwidth
      - alert: CriticalNetworkEgress
        expr: rate(node_network_transmit_bytes_total{device="enp87s0"}[5m]) * 8 > 800000000
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "Critical external network egress on {{ $labels.node }}"
          description: "External network egress on {{ $labels.node }} interface {{ $labels.device }} is {{ $value | humanize }}bps - approaching gigabit limit"

  - name: ycluster-services
    rules:
      # etcd cluster health - grouped by service to show cluster-wide status
      - alert: EtcdClusterUnhealthy
        expr: count(ycluster_service_health{service="etcd"} >= 2) >= 2
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "etcd cluster unhealthy"
          description: "etcd cluster is reporting unhealthy status on {{ $value }} nodes"

      # Ceph cluster health - grouped by service to show cluster-wide status
      - alert: CephClusterDegraded
        expr: count(ycluster_service_health{service="ceph"} >= 1) >= 2
        for: 1m
        labels:
          severity: warning
        annotations:
          summary: "Ceph cluster degraded"
          description: "Ceph cluster is reporting degraded status on {{ $value }} nodes"

      - alert: CephClusterUnhealthy
        expr: count(ycluster_service_health{service="ceph"} >= 2) >= 2
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "Ceph cluster unhealthy"
          description: "Ceph cluster is reporting unhealthy status on {{ $value }} nodes"

      # Leadership alerts
      - alert: NoStorageLeader
        expr: sum(ycluster_storage_leader) == 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "No storage leader elected"
          description: "No node is currently the storage leader"

      - alert: MultipleStorageLeaders
        expr: sum(ycluster_storage_leader) > 1
        for: 30s
        labels:
          severity: critical
        annotations:
          summary: "Multiple storage leaders detected"
          description: "{{ $value }} nodes claim to be storage leader - possible split brain"

      - alert: NoDHCPLeader
        expr: sum(ycluster_dhcp_leader) == 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "No DHCP leader elected"
          description: "No node is currently the DHCP leader"

      - alert: MultipleDHCPLeaders
        expr: sum(ycluster_dhcp_leader) > 1
        for: 30s
        labels:
          severity: critical
        annotations:
          summary: "Multiple DHCP leaders detected"
          description: "{{ $value }} nodes claim to be DHCP leader - possible split brain"

      # Certificate expiry warning - grouped by node
      - alert: CertificateExpiringWarning
        expr: min(ycluster_certificate_days_until_expiry) by (node) < 30 and min(ycluster_certificate_days_until_expiry) by (node) > 7
        for: 1h
        labels:
          severity: warning
        annotations:
          summary: "TLS certificate expiring soon on {{ $labels.node }}"
          description: "TLS certificate on {{ $labels.node }} will expire in {{ $value }} days"

      # Certificate expiry critical - grouped by node
      - alert: CertificateExpiringCritical
        expr: min(ycluster_certificate_days_until_expiry) by (node) <= 7
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "TLS certificate expiring very soon on {{ $labels.node }}"
          description: "TLS certificate on {{ $labels.node }} will expire in {{ $value }} days"

      # VIP not active anywhere
      - alert: VIPNotActive
        expr: max(ycluster_vip_active) by (vip) == 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "VIP {{ $labels.vip }} not active anywhere"
          description: "Virtual IP {{ $labels.vip }} is not active on any node"

      # Multiple VIP masters (split brain)
      - alert: MultipleVIPMasters
        expr: sum(ycluster_vip_active) by (vip) > 1
        for: 30s
        labels:
          severity: critical
        annotations:
          summary: "Multiple masters for VIP {{ $labels.vip }}"
          description: "VIP {{ $labels.vip }} is active on multiple nodes - possible split brain"

      # Held packages not upgraded for over 30 days
      - alert: HeldPackagesStale
        expr: (time() - ycluster_held_packages_last_upgrade_timestamp_seconds) > 30 * 24 * 3600
        for: 1h
        labels:
          severity: warning
        annotations:
          summary: "Held packages on {{ $labels.node }} not upgraded in over 30 days"
          description: "Run: cd /etc/ansible && ./run-playbook.sh storage/upgrade-held-packages.yml"

  - name: ycluster-storage-disks
    rules:
      # ZFS pool not ONLINE (DEGRADED / FAULTED / UNAVAIL / ...)
      - alert: ZfsPoolNotOnline
        expr: ycluster_zpool_state != 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "ZFS pool {{ $labels.pool }} on {{ $labels.node }} is {{ $labels.health }}"
          description: "Pool {{ $labels.pool }} is in state {{ $labels.health }} — investigate with `zpool status {{ $labels.pool }}`"

      # Any device-level read/write/cksum errors in a pool
      - alert: ZfsPoolDeviceErrors
        expr: ycluster_zpool_errors_total > 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "ZFS pool {{ $labels.pool }} has {{ $labels.type }} errors on {{ $labels.node }}"
          description: "Pool {{ $labels.pool }} has accumulated {{ $value }} {{ $labels.type }} errors — check `zpool status -v {{ $labels.pool }}`"

      # Pool-level data corruption
      - alert: ZfsPoolDataErrors
        expr: ycluster_zpool_data_errors > 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "ZFS pool {{ $labels.pool }} reports data errors on {{ $labels.node }}"
          description: "Pool {{ $labels.pool }} has {{ $value }} data errors — run `zpool status -v {{ $labels.pool }}` and consider restoring affected files"

      # Pool getting full
      - alert: ZfsPoolHighCapacity
        expr: ycluster_zpool_capacity_ratio > 0.85
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "ZFS pool {{ $labels.pool }} above 85% on {{ $labels.node }}"
          description: "Pool {{ $labels.pool }} is at {{ $value | humanizePercentage }} — ZFS write performance degrades sharply above 80–90%"

      - alert: ZfsPoolCriticalCapacity
        expr: ycluster_zpool_capacity_ratio > 0.95
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "ZFS pool {{ $labels.pool }} above 95% on {{ $labels.node }}"
          description: "Pool {{ $labels.pool }} is at {{ $value | humanizePercentage }} — free space or evict data immediately"

      # Scrub age — RAIDZ1 with 14TB disks should scrub regularly to catch bit rot
      - alert: ZfsScrubOverdue
        expr: (time() - ycluster_zpool_last_scrub_timestamp_seconds) > 60 * 24 * 3600 and ycluster_zpool_last_scrub_timestamp_seconds > 0
        for: 1h
        labels:
          severity: warning
        annotations:
          summary: "ZFS pool {{ $labels.pool }} has not been scrubbed in over 60 days"
          description: "Last scrub on {{ $labels.pool }} ({{ $labels.node }}) was over 60 days ago — run `zpool scrub {{ $labels.pool }}`"

      # Samba services on NAS nodes
      - alert: SambaDown
        expr: node_systemd_unit_state{name=~"smbd.service|nmbd.service",state="active"} == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "Samba {{ $labels.name }} not running on {{ $labels.node }}"
          description: "{{ $labels.name }} is not in active state on {{ $labels.node }} — clients cannot reach the share"

      # SMART health failure — drive is reporting overall self-assessment failed
      - alert: SmartDriveUnhealthy
        expr: smartmon_device_smart_healthy == 0
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "SMART unhealthy: {{ $labels.disk }} on {{ $labels.node }}"
          description: "Drive {{ $labels.disk }} on {{ $labels.node }} reports overall SMART health failure — replace the drive"

      # Pending sectors — pending reallocation, often a precursor to drive failure
      - alert: SmartPendingSectors
        expr: smartmon_current_pending_sector_raw_value > 0
        for: 30m
        labels:
          severity: warning
        annotations:
          summary: "SMART pending sectors on {{ $labels.disk }} ({{ $labels.node }})"
          description: "Drive {{ $labels.disk }} has {{ $value }} pending sectors — early warning of drive failure"

      # Reallocated sectors — drive has already remapped bad sectors
      - alert: SmartReallocatedSectors
        expr: smartmon_reallocated_sector_ct_raw_value > 0
        for: 1h
        labels:
          severity: warning
        annotations:
          summary: "SMART reallocated sectors on {{ $labels.disk }} ({{ $labels.node }})"
          description: "Drive {{ $labels.disk }} has reallocated {{ $value }} sectors — monitor for further degradation"

      # Offline-uncorrectable: data lost
      - alert: SmartOfflineUncorrectable
        expr: smartmon_offline_uncorrectable_raw_value > 0
        for: 30m
        labels:
          severity: critical
        annotations:
          summary: "SMART offline uncorrectable on {{ $labels.disk }} ({{ $labels.node }})"
          description: "Drive {{ $labels.disk }} reports {{ $value }} offline-uncorrectable sectors — replace the drive"

      # Drive temperature high. Different vendors expose temp under different SMART
      # attribute IDs (190 = airflow_temperature_cel, 194 = temperature_celsius);
      # the `or` matches whichever the drive reports.
      - alert: SmartDriveTemperatureHigh
        expr: (smartmon_airflow_temperature_cel_raw_value > 55) or (smartmon_temperature_celsius_raw_value > 55)
        for: 15m
        labels:
          severity: warning
        annotations:
          summary: "Drive {{ $labels.disk }} hot ({{ $value }}°C) on {{ $labels.node }}"
          description: "Drive {{ $labels.disk }} on {{ $labels.node }} has been above 55°C for 15 minutes"

      - alert: SmartDriveTemperatureCritical
        expr: (smartmon_airflow_temperature_cel_raw_value > 60) or (smartmon_temperature_celsius_raw_value > 60)
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "Drive {{ $labels.disk }} critically hot ({{ $value }}°C) on {{ $labels.node }}"
          description: "Drive {{ $labels.disk }} on {{ $labels.node }} is above 60°C — risk of imminent failure"

      # smartmon textfile collector stopped writing
      - alert: SmartmonStale
        expr: (time() - node_textfile_mtime_seconds{file="/var/lib/prometheus/node-exporter/smartmon.prom"}) > 3600
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "smartmon textfile collector stale on {{ $labels.node }}"
          description: "smartmon.prom on {{ $labels.node }} has not been updated in over an hour — SMART metrics may be stale"

  - name: ycluster-external
    rules:
      # No uplink available (informational)
      - alert: NoInternetUplink
        expr: max(ycluster_uplink_status) == 0
        for: 5m
        labels:
          severity: info
        annotations:
          summary: "No internet uplink available"
          description: "No nodes in the cluster have internet connectivity"

      # HTTPS domain accessibility - aggregated across all blackbox nodes
      - alert: HTTPSDomainDown
        expr: min(probe_success{job="https-domain"}) by (domain, instance) == 0
        for: 1m
        labels:
          severity: critical
          domain: '{{ $labels.domain }}'
          instance: '{{ $labels.instance }}'
        annotations:
          summary: "HTTPS domain {{ $labels.instance }} is down"
          description: "HTTPS domain {{ $labels.instance }} has been unreachable for more than 2 minutes"

      # HTTPS domain availability below 99% over 8 hours
      - alert: HTTPSDomainLowAvailability
        expr: avg(avg_over_time(probe_success{job="https-domain"}[8h])) by (domain, instance) < 0.99
        for: 5m
        labels:
          severity: warning
          domain: '{{ $labels.domain }}'
          instance: '{{ $labels.instance }}'
        annotations:
          summary: "HTTPS domain {{ $labels.instance }} availability below 99%"
          description: "HTTPS domain {{ $labels.instance }} has {{ $value | humanizePercentage }} availability over the past 8 hours (threshold: 99%)"

      # HTTPS certificate expiry (from blackbox) - only alert when uplink is available
      - alert: HTTPSCertificateExpiring
        expr: min((probe_ssl_earliest_cert_expiry{job="https-domain"} - time()) / 86400) by (domain, instance) < 30
        for: 1h
        labels:
          severity: warning
          domain: '{{ $labels.domain }}'
          instance: '{{ $labels.instance }}'
        annotations:
          summary: "HTTPS certificate expiring soon"
          description: "HTTPS certificate for {{ $labels.instance }} expires in {{ $value | humanizeDuration }}"

      # HTTPS certificate expiry critical - only alert when uplink is available
      - alert: HTTPSCertificateExpiringCritical
        expr: min((probe_ssl_earliest_cert_expiry{job="https-domain"} - time()) / 86400) by (domain, instance) < 7
        for: 5m
        labels:
          severity: critical
          domain: '{{ $labels.domain }}'
          instance: '{{ $labels.instance }}'
        annotations:
          summary: "HTTPS certificate expiring very soon"
          description: "HTTPS certificate for {{ $labels.instance }} expires in {{ $value | humanizeDuration }}"

      # HTTPS bad status codes (502, 503, 404, etc.) - only alert when uplink is available.
      # Scoped to http_2xx-module probes; http_401 probes legitimately see 401 as healthy
      # and their failure is already covered by HTTPSDomainDown via probe_success.
      # This is just defense in depth, because normally probe_success would be 0 for these too.
      - alert: HTTPSBadStatusCode
        expr: max(probe_http_status_code{job="https-domain",module="http_2xx"}) by (domain, instance) >= 400 and min(probe_success{job="https-domain",module="http_2xx"}) by (domain, instance) != 0
        for: 1m
        labels:
          severity: warning
          domain: '{{ $labels.domain }}'
          instance: '{{ $labels.instance }}'
        annotations:
          summary: "HTTPS domain {{ $labels.instance }} returning error status"
          description: "HTTPS domain {{ $labels.instance }} is returning HTTP status code {{ $value }} for more than 2 minutes"

      # HTTPS response time - only alert when uplink is available
      - alert: HTTPSSlowResponse
        expr: max(probe_duration_seconds{job="https-domain"}) by (domain, instance) > 10
        for: 5m
        labels:
          severity: warning
          domain: '{{ $labels.domain }}'
          instance: '{{ $labels.instance }}'
        annotations:
          summary: "HTTPS domain {{ $labels.instance }} slow response"
          description: "HTTPS domain {{ $labels.instance }} response time is {{ $value }}s (>10s) for more than 5 minutes"
