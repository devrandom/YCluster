# Prometheus configuration for YCluster local monitoring
global:
  scrape_interval: 15s
  evaluation_interval: 15s
  external_labels:
    cluster: 'ycluster'

rule_files:
  - "/etc/prometheus/rules/ycluster-alerts*.yml"

alerting:
  alertmanagers:
    - static_configs:
        - targets:
          - localhost:9093
{% for host in groups['core'] %}
{% if host != inventory_hostname %}
          - {{ hostvars[host]['ansible_host'] }}:9093
{% endif %}
{% endfor %}

scrape_configs:
  # Scrape Prometheus itself
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']
        labels:
          node: '{{ ansible_hostname }}'

  # Dynamic scrape targets via the local admin API.
  #
  # /api/prometheus/targets/<job> returns Prometheus http_sd format and
  # filters out hosts marked disabled in etcd (via `ycluster cluster
  # disable <host>`). Disabling a host takes effect on the next refresh
  # (refresh_interval below) — no ansible re-run required.

  - job_name: 'node-exporter'
    http_sd_configs:
      - url: 'http://127.0.0.1:12723/api/prometheus/targets/node-exporter'
        refresh_interval: 30s

  - job_name: 'ycluster-health'
    metrics_path: '/metrics'
    http_sd_configs:
      - url: 'http://127.0.0.1:12723/api/prometheus/targets/ycluster-health'
        refresh_interval: 30s

  - job_name: 'ycluster-dhcp'
    metrics_path: '/metrics'
    http_sd_configs:
      - url: 'http://127.0.0.1:12723/api/prometheus/targets/ycluster-dhcp'
        refresh_interval: 30s

  - job_name: 'ceph-exporter'
    http_sd_configs:
      - url: 'http://127.0.0.1:12723/api/prometheus/targets/ceph-exporter'
        refresh_interval: 30s

  # local-ai-proxy (inference gateway). Deployed on every storage node
  # but only the storage leader actually runs the service; standbys
  # report up=0, which is itself a useful signal. When the VIP fails
  # over to a different storage host, that host flips to up=1 and the
  # previous one to up=0.
  - job_name: 'inference-proxy'
    metrics_path: '/metrics'
    scrape_interval: 15s
    static_configs:
{% for host in groups['storage'] | default([]) %}
      - targets: ['{{ hostvars[host]['ansible_host'] }}:4001']
        labels:
          node: '{{ host }}'
{% endfor %}

  # Blackbox exporter for HTTPS domain monitoring.
  # Per-target module is set via file_sd labels (see update-blackbox-targets.py).
  - job_name: 'https-domain'
    scheme: https
    tls_config:
      ca_file: /etc/blackbox_exporter/tls/ca.crt
      cert_file: /etc/blackbox_exporter/tls/server.crt
      key_file: /etc/blackbox_exporter/tls/server.key
      insecure_skip_verify: false
    metrics_path: /probe
    file_sd_configs:
      - files:
        - '/etc/prometheus/blackbox-targets.json'
        refresh_interval: 30s
    relabel_configs:
      - source_labels: [__param_target]
        target_label: instance
      - source_labels: [module]
        target_label: __param_module

  # Blackbox exporter itself with TLS
  - job_name: 'blackbox-exporter'
    scheme: https
    tls_config:
      ca_file: /etc/blackbox_exporter/tls/ca.crt
      cert_file: /etc/blackbox_exporter/tls/server.crt
      key_file: /etc/blackbox_exporter/tls/server.key
      insecure_skip_verify: false
    static_configs:
      - targets: ['localhost:9115']
{% for host in groups['core'] %}
{% if host != inventory_hostname %}
      - targets: ['{{ hostvars[host]['ansible_host'] }}:9115']
        labels:
          node: '{{ host }}'
{% endif %}
{% endfor %}
{% if groups['frontend'] is defined %}
{% for host in groups['frontend'] %}
      - targets: ['{{ hostvars[host]['ansible_host'] }}:9115']
        labels:
          node: '{{ host }}'
          node_type: 'frontend'
{% endfor %}
{% endif %}

