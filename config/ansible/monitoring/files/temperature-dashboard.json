    {
      "type": "timeseries",
      "title": "Ambient (intake) temperature",
      "datasource": { "type": "prometheus", "uid": "prometheus-local" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 25 },
              { "color": "red", "value": 30 }
            ]
          },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "thresholdsStyle": { "mode": "line" } }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["last", "max"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-local" },
          "expr": "node_ipmi_temperature_celsius{role=\"ambient\"}",
          "legendFormat": "{{node}} / {{sensor}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-local" },
          "expr": "node_comino_temperature_celsius{role=\"ambient\"}",
          "legendFormat": "{{node}} / {{sensor}}",
          "refId": "B"
        }
      ]
    },
