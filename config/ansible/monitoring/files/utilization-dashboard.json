{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "timeseries",
      "title": "Network bandwidth (external interfaces)",
      "description": "RX (positive) + TX (negative) on physical en* interfaces only. Bridges (br-*, incusbr0, docker0), tap/veth, and loopback are excluded.",
      "datasource": { "type": "prometheus", "uid": "prometheus-local" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "axisCenteredZero": true }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["last", "mean", "max"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-local" },
          "expr": "rate(node_network_receive_bytes_total{node=~\"$node\",device=~\"en.*\"}[15m]) * 8",
          "legendFormat": "{{node}} {{device}} rx",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-local" },
          "expr": "-rate(node_network_transmit_bytes_total{node=~\"$node\",device=~\"en.*\"}[15m]) * 8",
          "legendFormat": "{{node}} {{device}} tx",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "GPU compute utilization (15-min average)",
      "description": "Host-side nvidia-smi (nv1, plus VFIO-pool GPUs that are unbound) and VM-side nvidia-smi (passthrough into Incus VMs). Total = mean across all selected GPUs.",
      "datasource": { "type": "prometheus", "uid": "prometheus-local" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Total" },
            "properties": [
              { "id": "custom.lineWidth", "value": 3 },
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "white" } }
            ]
          }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["last", "mean", "max"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-local" },
          "expr": "avg_over_time(node_gpu_utilization_percent{node=~\"$node\"}[15m])",
          "legendFormat": "{{node}} (host) gpu{{index}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-local" },
          "expr": "avg_over_time(node_vm_gpu_utilization_percent{node=~\"$node\"}[15m])",
          "legendFormat": "{{node}} / {{vm}} gpu{{index}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-local" },
          "expr": "avg(avg_over_time(node_gpu_utilization_percent{node=~\"$node\"}[15m]) or avg_over_time(node_vm_gpu_utilization_percent{node=~\"$node\"}[15m]))",
          "legendFormat": "Total",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "GPU power draw (15-min average)",
      "description": "Total = sum across all selected GPUs (aggregate cluster wattage).",
      "datasource": { "type": "prometheus", "uid": "prometheus-local" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 },
      "id": 3,
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Total" },
            "properties": [
              { "id": "custom.lineWidth", "value": 3 },
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "white" } }
            ]
          }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["last", "mean", "max"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-local" },
          "expr": "avg_over_time(node_gpu_power_watts{node=~\"$node\"}[15m])",
          "legendFormat": "{{node}} (host) gpu{{index}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-local" },
          "expr": "avg_over_time(node_vm_gpu_power_watts{node=~\"$node\"}[15m])",
          "legendFormat": "{{node}} / {{vm}} gpu{{index}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-local" },
          "expr": "sum(avg_over_time(node_gpu_power_watts{node=~\"$node\"}[15m]) or avg_over_time(node_vm_gpu_power_watts{node=~\"$node\"}[15m]))",
          "legendFormat": "Total",
          "refId": "C"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["ycluster", "utilization"],
  "templating": {
    "list": [
      {
        "name": "node",
        "label": "Node",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus-local" },
        "query": {
          "qryType": 1,
          "query": "label_values(node_network_receive_bytes_total, node)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "sort": 1,
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Utilization",
  "uid": "ycluster-utilization",
  "version": 1,
  "weekStart": ""
}
