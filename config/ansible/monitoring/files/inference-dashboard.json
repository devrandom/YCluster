{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Request rate",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus-local"},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}
        }
      },
      "targets": [
        {
          "expr": "sum(rate(local_ai_proxy_requests_total[5m]))",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus-local"}
        }
      ]
    },
    {
      "title": "Error rate",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus-local"},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "id": 2,
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.01},
              {"color": "red", "value": 0.05}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "(sum(rate(local_ai_proxy_requests_total{status=~\"4..|5..|transport_error\"}[5m])) or vector(0)) / (sum(rate(local_ai_proxy_requests_total[5m])) or vector(1))",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus-local"}
        }
      ]
    },
    {
      "title": "Backends healthy",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus-local"},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "id": 3,
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "green", "value": 2}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(local_ai_proxy_backend_healthy)",
          "legendFormat": "up",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus-local"}
        },
        {
          "expr": "count(local_ai_proxy_backend_healthy)",
          "legendFormat": "total",
          "refId": "B",
          "datasource": {"type": "prometheus", "uid": "prometheus-local"}
        }
      ]
    },
    {
      "title": "Retry rate",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus-local"},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "id": 4,
      "description": "Non-zero in steady state = quiet degradation. Alert trigger.",
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 3,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.01},
              {"color": "red", "value": 0.1}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(local_ai_proxy_retries_total[5m])) or vector(0)",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus-local"}
        }
      ]
    },
    {
      "title": "TTFT p95 — proxy vs backend (streaming)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus-local"},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 4},
      "id": 5,
      "description": "Solid lines: TTFT as the proxy saw it (handler entry -> first body byte). Dashed lines: vLLM's own ttft from its /metrics. The gap between them is proxy + network overhead. If it's growing, investigate the proxy host; if both are growing together, it's a backend (queue depth, compute) issue. vLLM-only — other backend types don't expose a native ttft metric.",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {"drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 1, "fillOpacity": 0, "showPoints": "never"}
        }
      },
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (model, le) (rate(local_ai_proxy_ttft_seconds_bucket{stream=\"true\"}[5m])))",
          "legendFormat": "proxy {{model}}",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus-local"}
        },
        {
          "expr": "histogram_quantile(0.95, sum by (model, le) (rate(vllm:time_to_first_token_seconds_bucket[5m])))",
          "legendFormat": "vllm {{model}}",
          "refId": "B",
          "datasource": {"type": "prometheus", "uid": "prometheus-local"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {"drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 1, "fillOpacity": 0, "showPoints": "never"}
        },
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": "^vllm "}, "properties": [{"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [5, 5]}}]}
        ]
      }
    },
    {
      "title": "Full request duration p95 by model",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus-local"},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 4},
      "id": 10,
      "description": "End-to-end time dominated by output length. Useful for capacity planning but noisy as a responsiveness signal — a p95 spike here often just means someone asked for a longer answer. Use TTFT instead for 'is it slow?'.",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {"drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 1, "fillOpacity": 0, "showPoints": "never"}
        }
      },
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (model, le) (rate(local_ai_proxy_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{model}}",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus-local"}
        }
      ]
    },
    {
      "title": "In-flight per backend",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus-local"},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 13},
      "id": 6,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {"calcs": ["max", "mean"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "local_ai_proxy_inflight",
          "legendFormat": "{{backend}}",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus-local"}
        }
      ]
    },
    {
      "title": "Retries by backend (reason)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus-local"},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 13},
      "id": 7,
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 20,
            "stacking": {"mode": "normal"},
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {"calcs": ["sum"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "sum by (backend, reason) (rate(local_ai_proxy_retries_total[5m]))",
          "legendFormat": "{{backend}} [{{reason}}]",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus-local"}
        }
      ]
    },
    {
      "title": "Backend health",
      "type": "table",
      "datasource": {"type": "prometheus", "uid": "prometheus-local"},
      "gridPos": {"h": 9, "w": 6, "x": 0, "y": 22},
      "id": 8,
      "description": "One row per backend, showing its current state (healthy / down / disabled / unknown).",
      "fieldConfig": {
        "defaults": {
          "custom": {"align": "auto", "cellOptions": {"type": "color-background"}},
          "mappings": [
            {"type": "value", "options": {
              "healthy":  {"color": "green",      "text": "healthy",  "index": 0},
              "down":     {"color": "red",        "text": "down",     "index": 1},
              "disabled": {"color": "dark-gray",  "text": "disabled", "index": 2},
              "unknown":  {"color": "light-gray", "text": "unknown",  "index": 3}
            }}
          ]
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "Value"}, "properties": [{"id": "custom.hidden", "value": true}]}
        ]
      },
      "options": {"showHeader": true, "footer": {"show": false}, "sortBy": [{"displayName": "State", "desc": false}]},
      "pluginVersion": "10",
      "targets": [
        {
          "expr": "max by (backend, state) (local_ai_proxy_backend_state) == 1",
          "instant": true,
          "format": "table",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus-local"}
        }
      ],
      "transformations": [
        {"id": "organize", "options": {
          "excludeByName": {"Time": true, "__name__": true, "job": true, "instance": true, "cluster": true},
          "renameByName": {"backend": "Backend", "state": "State"},
          "indexByName": {"backend": 0, "state": 1}
        }}
      ]
    },
    {
      "title": "Model health",
      "type": "table",
      "datasource": {"type": "prometheus", "uid": "prometheus-local"},
      "gridPos": {"h": 9, "w": 6, "x": 6, "y": 22},
      "id": 20,
      "description": "Healthy / total backends per model. Zero healthy means requests to that model fail with 503.",
      "fieldConfig": {
        "defaults": {
          "custom": {"align": "auto", "cellOptions": {"type": "color-background"}}
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "Healthy"}, "properties": [
            {"id": "custom.cellOptions", "value": {"type": "color-background"}},
            {"id": "thresholds", "value": {"mode": "absolute", "steps": [
              {"color": "red", "value": null},
              {"color": "orange", "value": 1},
              {"color": "green", "value": 2}
            ]}}
          ]}
        ]
      },
      "options": {"showHeader": true, "footer": {"show": false}, "sortBy": [{"displayName": "Healthy", "desc": false}]},
      "pluginVersion": "10",
      "targets": [
        {
          "expr": "max by (model) (local_ai_proxy_model_healthy_backends)",
          "instant": true,
          "format": "table",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus-local"}
        },
        {
          "expr": "max by (model) (local_ai_proxy_model_total_backends)",
          "instant": true,
          "format": "table",
          "refId": "B",
          "datasource": {"type": "prometheus", "uid": "prometheus-local"}
        }
      ],
      "transformations": [
        {"id": "merge", "options": {}},
        {"id": "organize", "options": {
          "excludeByName": {"Time": true, "__name__": true, "job": true, "instance": true, "cluster": true},
          "renameByName": {"model": "Model", "Value #A": "Healthy", "Value #B": "Total"},
          "indexByName": {"model": 0, "Value #A": 1, "Value #B": 2}
        }}
      ]
    },
    {
      "title": "Generation tokens/sec (vLLM)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus-local"},
      "gridPos": {"h": 9, "w": 6, "x": 0, "y": 31},
      "id": 11,
      "description": "Output tokens/sec per backend — steady-state decode throughput. Drops under queue contention; should match single-request tok/s when only one request is in flight.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 1, "fillOpacity": 0, "showPoints": "never"}
        }
      },
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "sum by (backend) (rate(vllm:generation_tokens_total[5m]))",
          "legendFormat": "{{backend}}",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus-local"}
        }
      ]
    },
    {
      "title": "Prompt tokens/sec (vLLM)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus-local"},
      "gridPos": {"h": 9, "w": 6, "x": 6, "y": 31},
      "id": 12,
      "description": "Input tokens/sec per backend — prompt-processing throughput. Dominated by context length; useful to see how much of the GPU is spent on prefill vs decode.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 1, "fillOpacity": 0, "showPoints": "never"}
        }
      },
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "sum by (backend) (rate(vllm:prompt_tokens_total[5m]))",
          "legendFormat": "{{backend}}",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus-local"}
        }
      ]
    },
    {
      "title": "KV cache pressure (vLLM)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus-local"},
      "gridPos": {"h": 9, "w": 6, "x": 12, "y": 31},
      "id": 13,
      "description": "Fraction of the KV cache in use. Climbs with concurrent requests and long contexts. Sustained >0.9 means the backend is about to start preempting; shorten contexts, cap concurrency, or scale out.",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {"drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 1, "fillOpacity": 15, "showPoints": "never"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.75},
              {"color": "red", "value": 0.9}
            ]
          }
        }
      },
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "vllm:kv_cache_usage_perc",
          "legendFormat": "{{backend}}",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus-local"}
        }
      ]
    },
    {
      "title": "Prefix cache hit rate (vLLM)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus-local"},
      "gridPos": {"h": 9, "w": 6, "x": 18, "y": 31},
      "id": 14,
      "description": "Fraction of queried prompt tokens served from the prefix cache over the last 5m. High = clients are reusing prompts (system prompts, multi-turn chats) and vLLM is amortizing prefill. Near zero = every request pays full prefill cost; check client prompt hygiene or raise --enable-prefix-caching if it's not already on.",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {"drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never"}
        }
      },
      "options": {
        "legend": {"calcs": ["mean"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "sum by (backend) (rate(vllm:prefix_cache_hits_total[5m])) / clamp_min(sum by (backend) (rate(vllm:prefix_cache_queries_total[5m])), 1)",
          "legendFormat": "{{backend}}",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus-local"}
        }
      ]
    },
    {
      "title": "Requests by model/backend/status",
      "type": "table",
      "datasource": {"type": "prometheus", "uid": "prometheus-local"},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 22},
      "id": 9,
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 3,
          "custom": {"align": "auto", "cellOptions": {"type": "auto"}}
        }
      },
      "options": {"showHeader": true, "footer": {"show": false}, "sortBy": [{"displayName": "Rate", "desc": true}]},
      "pluginVersion": "10",
      "targets": [
        {
          "expr": "sum by (model, backend, status) (rate(local_ai_proxy_requests_total[5m]))",
          "instant": true,
          "format": "table",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus-local"}
        }
      ],
      "transformations": [
        {"id": "organize", "options": {
          "excludeByName": {"Time": true, "__name__": true, "job": true, "instance": true, "cluster": true},
          "renameByName": {"model": "Model", "backend": "Backend", "status": "Status", "Value": "Rate"}
        }}
      ]
    }
  ],
  "refresh": "15s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["ycluster", "inference", "local-ai-proxy"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "YCluster Inference",
  "uid": "ycluster-inference",
  "version": 1,
  "weekStart": ""
}
