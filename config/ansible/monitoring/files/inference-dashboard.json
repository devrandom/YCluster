{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Request rate",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus-local"},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}
        }
      },
      "targets": [
        {
          "expr": "sum(rate(local_ai_proxy_requests_total[5m]))",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus-local"}
        }
      ]
    },
    {
      "title": "Error rate",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus-local"},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "id": 2,
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.01},
              {"color": "red", "value": 0.05}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "(sum(rate(local_ai_proxy_requests_total{status=~\"4..|5..|transport_error\"}[5m])) or vector(0)) / (sum(rate(local_ai_proxy_requests_total[5m])) or vector(1))",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus-local"}
        }
      ]
    },
    {
      "title": "Backends healthy",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus-local"},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "id": 3,
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "green", "value": 2}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(local_ai_proxy_backend_healthy)",
          "legendFormat": "up",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus-local"}
        },
        {
          "expr": "count(local_ai_proxy_backend_healthy)",
          "legendFormat": "total",
          "refId": "B",
          "datasource": {"type": "prometheus", "uid": "prometheus-local"}
        }
      ]
    },
    {
      "title": "Retry rate",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus-local"},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "id": 4,
      "description": "Non-zero in steady state = quiet degradation. Alert trigger.",
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 3,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.01},
              {"color": "red", "value": 0.1}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(local_ai_proxy_retries_total[5m])) or vector(0)",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus-local"}
        }
      ]
    },
    {
      "title": "Request latency (p50/p95/p99) by model",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus-local"},
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 4},
      "id": 5,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 0,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "right"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (model, le) (rate(local_ai_proxy_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{model}}",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus-local"}
        },
        {
          "expr": "histogram_quantile(0.95, sum by (model, le) (rate(local_ai_proxy_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{model}}",
          "refId": "B",
          "datasource": {"type": "prometheus", "uid": "prometheus-local"}
        },
        {
          "expr": "histogram_quantile(0.99, sum by (model, le) (rate(local_ai_proxy_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 {{model}}",
          "refId": "C",
          "datasource": {"type": "prometheus", "uid": "prometheus-local"}
        }
      ]
    },
    {
      "title": "In-flight per backend",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus-local"},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 13},
      "id": 6,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {"calcs": ["max", "mean"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "local_ai_proxy_inflight",
          "legendFormat": "{{backend}}",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus-local"}
        }
      ]
    },
    {
      "title": "Retries by backend (reason)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus-local"},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 13},
      "id": 7,
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 20,
            "stacking": {"mode": "normal"},
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {"calcs": ["sum"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "sum by (backend, reason) (rate(local_ai_proxy_retries_total[5m]))",
          "legendFormat": "{{backend}} [{{reason}}]",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus-local"}
        }
      ]
    },
    {
      "title": "Backend health",
      "type": "table",
      "datasource": {"type": "prometheus", "uid": "prometheus-local"},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 22},
      "id": 8,
      "description": "One row per backend, showing its current state (healthy / down / disabled / unknown).",
      "fieldConfig": {
        "defaults": {
          "custom": {"align": "auto", "cellOptions": {"type": "color-background"}},
          "mappings": [
            {"type": "value", "options": {
              "healthy":  {"color": "green",      "text": "healthy",  "index": 0},
              "down":     {"color": "red",        "text": "down",     "index": 1},
              "disabled": {"color": "dark-gray",  "text": "disabled", "index": 2},
              "unknown":  {"color": "light-gray", "text": "unknown",  "index": 3}
            }}
          ]
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "Value"}, "properties": [{"id": "custom.hidden", "value": true}]}
        ]
      },
      "options": {"showHeader": true, "footer": {"show": false}, "sortBy": [{"displayName": "State", "desc": false}]},
      "pluginVersion": "10",
      "targets": [
        {
          "expr": "local_ai_proxy_backend_state == 1",
          "instant": true,
          "format": "table",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus-local"}
        }
      ],
      "transformations": [
        {"id": "organize", "options": {
          "excludeByName": {"Time": true, "__name__": true, "job": true, "instance": true, "cluster": true, "node": false},
          "renameByName": {"backend": "Backend", "state": "State", "node": "Host"},
          "indexByName": {"backend": 0, "state": 1, "node": 2}
        }}
      ]
    },
    {
      "title": "Requests by model/backend/status",
      "type": "table",
      "datasource": {"type": "prometheus", "uid": "prometheus-local"},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 22},
      "id": 9,
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 3,
          "custom": {"align": "auto", "cellOptions": {"type": "auto"}}
        }
      },
      "options": {"showHeader": true, "footer": {"show": false}, "sortBy": [{"displayName": "Rate", "desc": true}]},
      "pluginVersion": "10",
      "targets": [
        {
          "expr": "sum by (model, backend, status) (rate(local_ai_proxy_requests_total[5m]))",
          "instant": true,
          "format": "table",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus-local"}
        }
      ],
      "transformations": [
        {"id": "organize", "options": {
          "excludeByName": {"Time": true, "__name__": true, "job": true, "instance": true, "cluster": true},
          "renameByName": {"model": "Model", "backend": "Backend", "status": "Status", "Value": "Rate"}
        }}
      ]
    }
  ],
  "refresh": "15s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["ycluster", "inference", "local-ai-proxy"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "Inference — local-ai-proxy",
  "uid": "ycluster-inference",
  "version": 1,
  "weekStart": ""
}
