#!/bin/bash
# YCluster WireGuard bootstrap
# Remote node joins the cluster over the internet via WireGuard.
# Allocates a normal cluster hostname+IP (as the chosen --type), generates
# a keypair, registers with the admin API, and waits for approval via
# `ycluster wg approve <hostname>`.
#
# Usage:
#   curl <api>/bootstrap/wg | sudo bash -s -- [--type TYPE] [--dev]
#
#   --type TYPE   node type: storage|compute|macos|nas|nvidia (default: compute)
#   --dev         skip host-level mutations (hostname, admin user, SSH hardening).
#                 Only the wg tunnel itself is brought up. Useful for dev boxes
#                 that are already personalised.

set -euo pipefail

LOG="/var/log/ycluster-bootstrap.log"
exec > >(tee -a "$LOG") 2>&1

echo "=== YCluster wg bootstrap $(date) ==="

API_SERVER="{{ api_server }}"
POLL_INTERVAL="${POLL_INTERVAL:-5}"
POLL_TIMEOUT="${POLL_TIMEOUT:-3600}"
ADMIN_USER="admin"

# --- arg parsing ----------------------------------------------------------
NODE_TYPE=""
DEV=0
while (( $# > 0 )); do
    case "$1" in
        --type)   NODE_TYPE="$2"; shift 2 ;;
        --type=*) NODE_TYPE="${1#*=}"; shift ;;
        --dev)    DEV=1; shift ;;
        -h|--help)
            sed -n '2,15p' "$0" 2>/dev/null || true
            echo "curl ... | sudo bash -s -- [--type TYPE] [--dev]"
            exit 0
            ;;
        *) echo "ERROR: unknown arg '$1'"; exit 1 ;;
    esac
done

# --dev implies --type dev unless the caller set an explicit --type
if [[ -z "$NODE_TYPE" ]]; then
    if (( DEV == 1 )); then
        NODE_TYPE="dev"
    else
        NODE_TYPE="compute"
    fi
fi

case "$NODE_TYPE" in
    storage|compute|macos|nas|nvidia|dev) ;;
    *) echo "ERROR: invalid --type '$NODE_TYPE' (must be storage|compute|macos|nas|nvidia|dev)"; exit 1 ;;
esac
echo "node_type=$NODE_TYPE dev=$DEV"

# --- install deps ---------------------------------------------------------
export DEBIAN_FRONTEND=noninteractive
apt-get update -qq
apt-get install -y -qq wireguard wireguard-tools jq curl iproute2

# --- allocate + register --------------------------------------------------
IFACE=$(ip route get 1.1.1.1 2>/dev/null | awk '/dev/{for(i=1;i<=NF;i++) if($i=="dev") print $(i+1); exit}')
if [[ -z "$IFACE" ]]; then
    echo "ERROR: could not determine default route interface"; ip route show; exit 1
fi
MAC=$(ip link show "$IFACE" | awk '/ether/{print $2; exit}')
echo "iface=$IFACE mac=$MAC"

install -d -m 700 /etc/wireguard
umask 077
PRIVKEY=$(wg genkey)
PUBKEY=$(echo "$PRIVKEY" | wg pubkey)
echo "pubkey=$PUBKEY"

# Atomic: allocate cluster hostname+IP AND record wg pubkey as pending peer
REG=$(curl -sfL -X POST \
    -H "Content-Type: application/json" \
    -d "$(jq -nc --arg m "$MAC" --arg t "$NODE_TYPE" --arg pk "$PUBKEY" \
            '{mac:$m, type:$t, pubkey:$pk}')" \
    "$API_SERVER/api/wg/register")
if [[ -z "$REG" ]]; then
    echo "ERROR: register call failed"; exit 1
fi
NEW_HOSTNAME=$(echo "$REG" | jq -r '.hostname')
IP_ADDRESS=$(echo "$REG" | jq -r '.ip')
FP=$(echo "$REG" | jq -r '.pubkey_sha256')
echo "allocated hostname=$NEW_HOSTNAME ip=$IP_ADDRESS fingerprint=$FP"
echo ""
echo "Waiting for approval. On the admin host run:"
echo "    ycluster wg approve $NEW_HOSTNAME"
echo ""

# --- poll for approval ----------------------------------------------------
DEADLINE=$(( $(date +%s) + POLL_TIMEOUT ))
CONFIG=""
while (( $(date +%s) < DEADLINE )); do
    POLL=$(curl -sfL "$API_SERVER/api/wg/poll/$NEW_HOSTNAME?fp=$FP" || true)
    if [[ -n "$POLL" ]]; then
        STATUS=$(echo "$POLL" | jq -r '.status // empty')
        case "$STATUS" in
            approved)
                CONFIG=$(echo "$POLL" | jq -r '.config')
                break
                ;;
            revoked)
                echo "ERROR: registration was revoked"; exit 1 ;;
            pending|"")
                ;;
            *)
                echo "WARN: unexpected status='$STATUS'" ;;
        esac
    fi
    sleep "$POLL_INTERVAL"
done

if [[ -z "$CONFIG" ]]; then
    echo "ERROR: timed out waiting for approval after ${POLL_TIMEOUT}s"
    exit 1
fi

# --- write wg0.conf + bring up --------------------------------------------
echo "$CONFIG" | sed "s|__PRIVATE_KEY__|$PRIVKEY|" > /etc/wireguard/wg0.conf
chmod 600 /etc/wireguard/wg0.conf
echo "wrote /etc/wireguard/wg0.conf"

if (( DEV == 0 )); then
    # Set hostname
    hostnamectl set-hostname "$NEW_HOSTNAME"
    if ! grep -q "127.0.1.1.*$NEW_HOSTNAME" /etc/hosts; then
        echo "127.0.1.1 $NEW_HOSTNAME" >> /etc/hosts
    fi

    # Admin user + SSH key so Ansible can reach this node once wg is up
    if ! id "$ADMIN_USER" &>/dev/null; then
        useradd -m -s /bin/bash -G sudo "$ADMIN_USER"
        passwd -l "$ADMIN_USER"
    else
        usermod -aG sudo "$ADMIN_USER"
    fi
    echo "$ADMIN_USER ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/"$ADMIN_USER"
    chmod 440 /etc/sudoers.d/"$ADMIN_USER"

    USER_HOME=$(getent passwd "$ADMIN_USER" | cut -d: -f6)
    SSH_DIR="$USER_HOME/.ssh"
    mkdir -p "$SSH_DIR"
    cat >> "$SSH_DIR/authorized_keys" <<'SSHKEY'
{{ ssh_key_content }}
SSHKEY
    chown -R "$ADMIN_USER":"$ADMIN_USER" "$SSH_DIR"
    chmod 700 "$SSH_DIR"
    chmod 600 "$SSH_DIR/authorized_keys"

    systemctl enable ssh || true
    systemctl start ssh || true
    sed -i 's/^#*PasswordAuthentication.*/PasswordAuthentication no/' /etc/ssh/sshd_config
    sed -i 's/^#*ChallengeResponseAuthentication.*/ChallengeResponseAuthentication no/' /etc/ssh/sshd_config
    systemctl reload ssh || true
else
    echo "dev mode: skipping hostname / admin user / SSH hardening"
fi

# Bring up the tunnel
systemctl enable wg-quick@wg0
systemctl restart wg-quick@wg0

echo ""
echo "=== wg bootstrap complete ==="
echo "Hostname: $NEW_HOSTNAME"
echo "Cluster IP: $IP_ADDRESS (on wg0)"
echo "Verify with: wg show wg0"
