#!/bin/bash
# YCluster macOS Bootstrap Script

set -euo pipefail

LOG="/var/log/ycluster-bootstrap.log"
exec > >(tee -a "$LOG") 2>&1

echo "=== YCluster macOS Bootstrap $(date) ==="

# API server that served this script
API_SERVER="{{ api_server }}"

# Get MAC address of primary interface (en0)
MAC_ADDRESS=$(/sbin/ifconfig en0 | /usr/bin/awk '/ether/{print $2}')
if [[ -z "$MAC_ADDRESS" ]]; then
    echo "ERROR: Could not determine MAC address for en0"
    exit 1
fi
echo "MAC Address: $MAC_ADDRESS"

# Call allocation API to get hostname and IP
echo "Fetching allocation from $API_SERVER..."
ALLOCATION=$(/usr/bin/curl -sf "$API_SERVER/api/allocate?mac=$MAC_ADDRESS&type=macos")
if [[ -z "$ALLOCATION" ]]; then
    echo "ERROR: Failed to get allocation from API"
    exit 1
fi

# Parse JSON response
HOSTNAME=$(echo "$ALLOCATION" | jq -r '.hostname')
IP_ADDRESS=$(echo "$ALLOCATION" | jq -r '.ip')

echo "Hostname: $HOSTNAME"
echo "IP: $IP_ADDRESS"

ADMIN_USER="admin"

# Create admin user if not exists
if ! dscl . -read /Users/"$ADMIN_USER" &>/dev/null; then
    echo "Creating admin user: $ADMIN_USER"
    # Create with temporary password, then disable it
    sysadminctl -addUser "$ADMIN_USER" \
        -password "$(uuidgen)" \
        -admin \
        -shell /bin/bash
    # Disable password (SSH key only)
    dscl . -create /Users/"$ADMIN_USER" Password '*'
    echo "User $ADMIN_USER created (password disabled)"
else
    echo "User $ADMIN_USER already exists"
fi

# Configure passwordless sudo
echo "Configuring passwordless sudo for $ADMIN_USER..."
echo "$ADMIN_USER ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/"$ADMIN_USER"
chmod 440 /etc/sudoers.d/"$ADMIN_USER"

# Set up SSH key
USER_HOME=$(dscl . -read /Users/"$ADMIN_USER" NFSHomeDirectory | awk '{print $2}')
SSH_DIR="$USER_HOME/.ssh"

mkdir -p "$SSH_DIR"
cat >> "$SSH_DIR/authorized_keys" <<'SSHKEY'
{{ ssh_key_content }}
SSHKEY

chown -R "$ADMIN_USER":staff "$SSH_DIR"
chmod 700 "$SSH_DIR"
chmod 600 "$SSH_DIR/authorized_keys"
echo "SSH key installed for $ADMIN_USER"

# Set hostname
echo "Setting hostname to: $HOSTNAME"
scutil --set ComputerName "$HOSTNAME"
scutil --set LocalHostName "$HOSTNAME"
scutil --set HostName "$HOSTNAME"

# Enable SSH (Remote Login)
echo "Enabling Remote Login (SSH)..."
systemsetup -setremotelogin on

# Install Xcode Command Line Tools — this supplies the python that Ansible
# needs, so it's a prerequisite for the node being manageable at all (the
# wg-macos path gets CLT transitively via its Homebrew prerequisite instead).
# The rest of the host hardening (sleep/power, SSH key-only) is applied by
# Ansible (macos/setup-macos.yml) once the node is reachable.
if ! xcode-select -p &>/dev/null; then
    echo "Installing Xcode Command Line Tools..."
    # This marker file makes softwareupdate list the CLT
    touch /tmp/.com.apple.dt.CommandLineTools.installondemand.in-progress
    # Extract the label (e.g., "Command Line Tools for Xcode 26.2-26.2")
    # Must use Label line, not Title, as softwareupdate -i needs the exact label
    PROD=$(softwareupdate -l 2>&1 | grep "^\* Label:" | grep -o "Command Line Tools.*" | head -1)
    if [[ -n "$PROD" ]]; then
        echo "Installing: $PROD"
        softwareupdate -i "$PROD" --verbose || echo "Warning: softwareupdate failed, may need manual install"
    else
        echo "Warning: Command Line Tools not found in software updates"
        echo "Try running 'xcode-select --install' manually"
    fi
    rm -f /tmp/.com.apple.dt.CommandLineTools.installondemand.in-progress
else
    echo "Xcode Command Line Tools already installed at $(xcode-select -p)"
fi

# Disable sleep (and auto-restart after power loss). This is a reachability
# prerequisite, not just hardening: a sleeping Mac drops its network (and any
# wg tunnel), so Ansible could never reach it to apply these — it has to happen
# at bootstrap. setup-macos.yml re-asserts the same values.
# disablesleep 1 is the key one on Apple Silicon: `sleep 0` only disables the
# idle timer, NOT "maintenance sleep" (the Mac still DarkWakes/sleeps in cycles,
# answering pings via NIC offload while userspace/services hang). disablesleep
# is what actually keeps it fully awake.
echo "Disabling sleep / enabling auto-restart..."
pmset -a sleep 0 disksleep 0 displaysleep 1 hibernatemode 0 powernap 0 standby 0 autopoweroff 0 autorestart 1 disablesleep 1

echo "=== Bootstrap complete ==="
echo "SSH should now be available at $IP_ADDRESS"
echo ""
echo "Admin users:"
dscl . -read /Groups/admin GroupMembership | sed 's/GroupMembership: /  /'
