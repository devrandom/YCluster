#!/bin/bash
# Configure the VM-access bastion: a jump-only sshd plus a rathole client.
# Generated by Ansible (install-vm-bastion.yml); runs inside the bastion
# container. Idempotent — safe to re-run. On a no-op run it writes
# nothing and restarts no services.
#
# The jump user's authorized_keys is NOT written here — it is generated
# from the etcd registries by `ycluster vm bastion-sync`. Each key line
# there is restricted to port-forwarding into that owner's VMs only.
set -euo pipefail

JUMP_USER="{{ vm_bastion_jump_user }}"
RATHOLE_SERVICE="{{ vm_bastion_service }}"

# Track what needs to happen so we don't restart services or print the
# "Bastion configured" banner on no-op runs.
changed=0
restart_ssh=0
restart_rathole=0
reload_systemd=0

# Write stdin to $1 (mode $2, default 0644) iff content differs from what
# is already there. Sets `changed=1` on write; echoes "changed" or
# "unchanged" for the caller to act on. Atomic via mktemp + mv.
write_if_changed() {
    local dest="$1" mode="${2:-0644}" tmp
    tmp=$(mktemp)
    cat > "$tmp"
    chmod "$mode" "$tmp"
    if [ -f "$dest" ] && cmp -s "$tmp" "$dest"; then
        rm -f "$tmp"
        echo unchanged
    else
        mv "$tmp" "$dest"
        changed=1
        echo changed
    fi
}

# --- apt: install openssh-server only on first run ---
# `apt-get update` is a network round-trip; skip it when the package is
# already there. First-run path still works because the container's apt
# cache is fresh from the image build.
if ! dpkg -s openssh-server >/dev/null 2>&1; then
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq
    apt-get install -y -qq openssh-server >/dev/null
    changed=1
    restart_ssh=1
fi

# --- jump user (no shell, no password) ---
if ! id "$JUMP_USER" &>/dev/null; then
    useradd --create-home --shell /usr/sbin/nologin "$JUMP_USER"
    changed=1
fi
install -d -m 700 -o "$JUMP_USER" -g "$JUMP_USER" "/home/$JUMP_USER/.ssh"
# Seed an empty authorized_keys so sshd is happy until bastion-sync runs.
[ -e "/home/$JUMP_USER/.ssh/authorized_keys" ] || \
    install -m 600 -o "$JUMP_USER" -g "$JUMP_USER" /dev/null \
        "/home/$JUMP_USER/.ssh/authorized_keys"

# --- jump-only sshd policy ---
# Per-key restrictions in authorized_keys (restrict,port-forwarding,
# permitopen=...) do the real enforcement; this is the coarse gate.
sshd_state=$(cat <<EOF | write_if_changed /etc/ssh/sshd_config.d/10-bastion.conf
# Managed by Ansible — VM-access jump host only.
PasswordAuthentication no
PermitRootLogin no
AllowUsers $JUMP_USER
X11Forwarding no
AllowAgentForwarding no
EOF
)
[ "$sshd_state" = changed ] && restart_ssh=1

# Ubuntu 24.04 ships ssh socket-activated; switch to the plain service so
# the port is always listening for rathole and config changes apply cleanly.
if systemctl is-enabled ssh.socket >/dev/null 2>&1; then
    systemctl disable --now ssh.socket
    changed=1
    restart_ssh=1
fi
if ! systemctl is-enabled ssh.service >/dev/null 2>&1; then
    systemctl enable ssh.service
    changed=1
    restart_ssh=1
fi

# --- rathole client ---
install -d -m 755 /etc/rathole

rathole_state=$(cat <<EOF | write_if_changed /etc/rathole/bastion.toml 0600
[client]
remote_addr = "{{ rathole_remote_addr }}"
default_token = "{{ rathole_token }}"
heartbeat_timeout = 40
retry_interval = 1

[client.transport]
type = "tcp"

[client.transport.tcp]
nodelay = true
keepalive_secs = 20
keepalive_interval = 8

[client.services.$RATHOLE_SERVICE]
local_addr = "127.0.0.1:22"
type = "tcp"
EOF
)
[ "$rathole_state" = changed ] && restart_rathole=1

unit_state=$(cat <<EOF | write_if_changed /etc/systemd/system/rathole-bastion.service
[Unit]
Description=rathole client (VM-access bastion tunnel)
After=network-online.target
Wants=network-online.target

[Service]
ExecStart=/usr/local/bin/rathole /etc/rathole/bastion.toml
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
EOF
)
if [ "$unit_state" = changed ]; then
    reload_systemd=1
    restart_rathole=1
fi
if ! systemctl is-enabled rathole-bastion.service >/dev/null 2>&1; then
    [ "$reload_systemd" = 1 ] || { systemctl daemon-reload; reload_systemd=1; }
    systemctl enable rathole-bastion.service
    changed=1
    restart_rathole=1
fi
[ "$reload_systemd" = 1 ] && [ "$unit_state" = changed ] && systemctl daemon-reload

# The rathole binary on disk is managed by the playbook (checksum-gated
# push + atomic-rename + explicit restart on replacement), so we don't
# detect binary changes here.

[ "$restart_ssh" = 1 ] && systemctl restart ssh.service
[ "$restart_rathole" = 1 ] && systemctl restart rathole-bastion.service

if [ "$changed" = 1 ] || [ "$restart_ssh" = 1 ] || [ "$restart_rathole" = 1 ]; then
    # Avoid bash's array-length syntax here — Jinja parses an open-brace
    # followed by hash as a comment-block opener and the render fails.
    restarted=""
    [ "$restart_ssh" = 1 ] && restarted="ssh"
    [ "$restart_rathole" = 1 ] && restarted="${restarted:+$restarted, }rathole"
    detail=""
    [ -n "$restarted" ] && detail=" ($restarted restarted)"
    echo "Bastion configured: rathole service '$RATHOLE_SERVICE' -> jump sshd$detail."
else
    echo "Bastion: no changes."
fi
