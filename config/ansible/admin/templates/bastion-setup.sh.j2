#!/bin/bash
# Configure the VM-access bastion: a jump-only sshd plus a rathole client.
# Generated by Ansible (install-vm-bastion.yml); runs inside the bastion
# container. Idempotent — safe to re-run.
#
# The jump user's authorized_keys is NOT written here — it is generated
# from the etcd registries by `ycluster vm bastion-sync`. Each key line
# there is restricted to port-forwarding into that owner's VMs only.
set -euo pipefail

JUMP_USER="{{ vm_bastion_jump_user }}"
RATHOLE_SERVICE="{{ vm_bastion_service }}"

export DEBIAN_FRONTEND=noninteractive
apt-get update -qq
apt-get install -y -qq openssh-server >/dev/null

# --- jump user (no shell, no password) ---
id "$JUMP_USER" &>/dev/null || \
    useradd --create-home --shell /usr/sbin/nologin "$JUMP_USER"
install -d -m 700 -o "$JUMP_USER" -g "$JUMP_USER" "/home/$JUMP_USER/.ssh"
# Seed an empty authorized_keys so sshd is happy until bastion-sync runs.
[ -e "/home/$JUMP_USER/.ssh/authorized_keys" ] || \
    install -m 600 -o "$JUMP_USER" -g "$JUMP_USER" /dev/null \
        "/home/$JUMP_USER/.ssh/authorized_keys"

# --- jump-only sshd policy ---
# Per-key restrictions in authorized_keys (restrict,port-forwarding,
# permitopen=...) do the real enforcement; this is the coarse gate.
cat > /etc/ssh/sshd_config.d/10-bastion.conf <<EOF
# Managed by Ansible — VM-access jump host only.
PasswordAuthentication no
PermitRootLogin no
AllowUsers $JUMP_USER
X11Forwarding no
AllowAgentForwarding no
EOF

# Ubuntu 24.04 ships ssh socket-activated; use the plain service so the
# port is always listening for rathole and config changes apply cleanly.
systemctl disable --now ssh.socket 2>/dev/null || true
systemctl enable ssh.service
systemctl restart ssh.service

# --- rathole client ---
install -d -m 755 /etc/rathole
umask 077
cat > /etc/rathole/bastion.toml <<EOF
[client]
remote_addr = "{{ rathole_remote_addr }}"
default_token = "{{ rathole_token }}"
heartbeat_timeout = 40
retry_interval = 1

[client.transport]
type = "tcp"

[client.transport.tcp]
nodelay = true
keepalive_secs = 20
keepalive_interval = 8

[client.services.$RATHOLE_SERVICE]
local_addr = "127.0.0.1:22"
type = "tcp"
EOF
umask 022

cat > /etc/systemd/system/rathole-bastion.service <<EOF
[Unit]
Description=rathole client (VM-access bastion tunnel)
After=network-online.target
Wants=network-online.target

[Service]
ExecStart=/usr/local/bin/rathole /etc/rathole/bastion.toml
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
EOF
systemctl daemon-reload
systemctl enable rathole-bastion.service
systemctl restart rathole-bastion.service

echo "Bastion configured: rathole service '$RATHOLE_SERVICE' -> jump sshd."
