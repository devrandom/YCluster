name: gpu-ct
description: GPU-sharing LXC container (host kernel, /dev/kfd + /dev/dri)
config:
  limits.cpu: "8"
  limits.memory: 32GiB
  # Map the host's 'render' group (gid {{ incus_render_gid }}) into the
  # container with the same gid, so the bind-mounted /dev/kfd and
  # /dev/dri/renderD128 (mode 660 root:render on the host) appear as
  # root:render inside. The ubuntu-rocm image preallocates a 'render'
  # group at the matching gid and makes the default ubuntu user a member,
  # so ROCm works without sudo.
  raw.idmap: |-
    gid {{ incus_render_gid }} {{ incus_render_gid }}
devices:
  eth0:
    type: nic
    network: {{ incus_bridge }}
    name: eth0
    # Isolation ACL is applied at the network level (see install-incus.yml).
  root:
    type: disk
    path: /
    pool: {{ incus_storage_pool }}
    size: 40GiB
  # All containers attached to this profile share the host's single GPU.
  # 'gputype=physical' on a container bind-mounts only the DRM nodes
  # (/dev/dri/cardN, /dev/dri/renderDN). ROCm compute also needs the
  # /dev/kfd char device, which incus does not include — attach it as a
  # plain unix-char device. No vfio, no driver rebind, no VRAM quota.
  gpu0:
    type: gpu
    gputype: physical
    uid: "0"
    gid: "{{ incus_render_gid }}"
    mode: "0660"
  kfd:
    type: unix-char
    source: /dev/kfd
    path: /dev/kfd
    uid: "0"
    gid: "{{ incus_render_gid }}"
    mode: "0660"
---
