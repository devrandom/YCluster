#!/bin/bash
# Split the GPUs at boot: bind the passthrough GPUs (and their HD-Audio
# functions) to vfio-pci, then load the nvidia driver for the host GPUs.
#
# Ordering matters. nvidia is blocked from loading by
# /etc/modprobe.d/nvidia-deferred.conf ('install ... /bin/false') so nothing
# can bind a passthrough GPU to nvidia before this script binds it to
# vfio-pci -- a runtime nvidia->vfio-pci rebind of a GPU function hangs
# in-kernel and only a reboot clears it.
#
# Generated by Ansible (install-incus.yml).
set -eu

passthrough=( {{ incus_passthrough_all | join(' ') }} )

modprobe vfio-pci

for addr in "${passthrough[@]}"; do
    dev="/sys/bus/pci/devices/$addr"
    cur=""
    [ -L "$dev/driver" ] && cur=$(basename "$(readlink -f "$dev/driver")")
    [ "$cur" = vfio-pci ] && continue
    if [ "$cur" = nvidia ]; then
        # Unbinding a live nvidia GPU function hangs in-kernel -- never do it.
        echo "ERROR: $addr is bound to nvidia; refusing live rebind. Reboot" \
             "to apply passthrough binding." >&2
        exit 1
    fi
    echo vfio-pci > "$dev/driver_override"
    [ -n "$cur" ] && echo "$addr" > "$dev/driver/unbind"
    echo "$addr" > /sys/bus/pci/drivers_probe
done

# All passthrough GPUs are now on vfio-pci; load nvidia for the host GPUs.
# --ignore-install bypasses the /bin/false guard in nvidia-deferred.conf.
for mod in nvidia nvidia_modeset nvidia_uvm nvidia_drm; do
    modprobe --ignore-install "$mod"
done
