#!/bin/bash
# Build the 'ubuntu-cuda-vllm' Incus VM image: the 'ubuntu-cuda' base image
# with vLLM preinstalled (as a uv tool, under the 'ubuntu' user) and the
# FlashInfer SM120 kernel cache AOT-baked in.
#
# This is a layered build -- it starts from 'ubuntu-cuda', so that image must
# exist first (incus-build-gpu-image). vLLM churns faster than the CUDA base,
# so keeping them as two images means a vLLM bump does not force a full CUDA
# rebuild.
#
# uv is installed from PyPI (astral-sh's own publish), pinned to an exact
# version and SHA256-verified -- not from the third-party 'astral-uv' snap,
# which auto-refreshes and is community-repackaged.
#
# The AOT step compiles FlashInfer's CUTLASS MoE / NVFP4 kernels for SM120
# ahead of time and lands them in <wheel>/data/aot/ where the runtime
# JitSpec.aot_path looks. Without it, vLLM JIT-compiles them on first start
# (~10 min for MiniMax-M2.7-NVFP4). With it, ~70 s. See
# docs/operations/vm-hosting.md "Pre-warm the FlashInfer kernel cache".
#
# Generated by Ansible (install-incus.yml).
set -euo pipefail

ALIAS="ubuntu-cuda-vllm"
BASE="ubuntu-cuda"
BUILDER="vllm-image-builder"
VLLM_VERSION="{{ vllm_version }}"
UV_VERSION="{{ uv_version }}"
UV_SHA256="{{ uv_sha256 }}"
FLASHINFER_VERSION="{{ flashinfer_version }}"

if [[ "${1:-}" != "--force" ]] && incus image alias list --format csv | grep -q "^${ALIAS},"; then
    echo "Image '$ALIAS' already exists. Pass --force to rebuild."
    exit 0
fi

if ! incus image alias list --format csv | grep -q "^${BASE},"; then
    echo "Base image '$BASE' not found -- run incus-build-gpu-image first." >&2
    exit 1
fi

cleanup() { incus delete --force "$BUILDER" 2>/dev/null || true; }
trap cleanup EXIT

incus delete --force "$BUILDER" 2>/dev/null || true

echo "==> Launching builder VM from $BASE..."
# 48 GiB RAM: each nvcc 'cicc' job for CUTLASS FP4/FP8 SM120 kernels peaks
# above 5 GiB RSS; MAX_JOBS=8 (below) needs ~8 × 5 GiB + ~8 GiB OS/ninja
# headroom. At 32 GiB / MAX_JOBS=8 the in-VM OOM killer fires partway
# through (verified — global_oom reaping cicc and the incus-agent).
# 80 GiB disk: ~30 GiB for the build tree (cutlass clone + cached_ops
# intermediate objects) on top of the vLLM install, cleaned up before publish.
incus launch "$BASE" "$BUILDER" --vm \
    -c limits.cpu=8 -c limits.memory=48GiB \
    -d root,size=80GiB

echo "==> Waiting for guest agent..."
for _ in $(seq 1 60); do
    incus exec "$BUILDER" -- true 2>/dev/null && break
    sleep 5
done
incus exec "$BUILDER" -- cloud-init status --wait || true

echo "==> Installing vLLM build/runtime dependencies and uv..."
# python3-dev / ninja-build / cmake: vLLM JIT-compiles CUDA kernels at
# runtime (Triton / inductor) and needs these present in the guest. They
# are also what flashinfer.aot uses to compile its kernels ahead of time
# in the AOT step below.
# git: needed to clone the flashinfer source tree for the AOT build.
incus exec "$BUILDER" -- bash -euxc "
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y python3-dev python3-venv ninja-build cmake git
    apt-get clean
    # uv: pinned + hash-verified from PyPI (uv has no dependencies, so
    # --require-hashes needs only its own hash).
    python3 -m venv /opt/uv-venv
    printf 'uv==%s --hash=sha256:%s\n' '${UV_VERSION}' '${UV_SHA256}' \
        > /tmp/uv-req.txt
    /opt/uv-venv/bin/pip install --require-hashes -r /tmp/uv-req.txt
    install -m 0755 /opt/uv-venv/bin/uv /usr/local/bin/uv
    rm -f /tmp/uv-req.txt
"

echo "==> Installing vLLM ${VLLM_VERSION} (uv tool, user 'ubuntu')..."
incus exec "$BUILDER" -- sudo -u ubuntu bash -lc \
    "uv tool install vllm==${VLLM_VERSION}"

echo "==> Verifying flashinfer version matches the pinned source tag..."
# Mismatch would silently bypass the AOT cache at runtime (the wheel's
# version-check raises, falling back to the in-package data/aot).
WHEEL_FI_VER=$(incus exec "$BUILDER" -- sudo -u ubuntu \
    /home/ubuntu/.local/share/uv/tools/vllm/bin/python -c \
    'import flashinfer; print(flashinfer.__version__)' | tr -d '\r')
if [[ "$WHEEL_FI_VER" != "$FLASHINFER_VERSION" ]]; then
    echo "ERROR: flashinfer in wheel is $WHEEL_FI_VER but flashinfer_version=$FLASHINFER_VERSION." >&2
    echo "  Update flashinfer_version in install-incus.yml to match." >&2
    exit 1
fi

echo "==> AOT-compiling FlashInfer SM120 kernels (~40 min, MAX_JOBS=8)..."
# Wrapper script: drive compile_and_package_modules from the installed
# wheel (so version checks pass) but point project_root at the cloned
# source tree (the wheel ships data/csrc but the AOT script expects the
# full src layout incl. 3rdparty/cutlass). FLASHINFER_CUDA_ARCH_LIST=12.0
# is auto-normalised to compute_120f under CUDA >= 12.9; the SM120 module
# generators substring-match "compute_120", so this still enables them.
incus exec "$BUILDER" -- sudo -u ubuntu bash -euxc "
    cd /home/ubuntu
    git clone --depth 1 --branch v${FLASHINFER_VERSION} \
        https://github.com/flashinfer-ai/flashinfer.git src
    cd src
    git submodule update --init --depth 1 3rdparty/cutlass 3rdparty/spdlog

    cat > /home/ubuntu/run_aot.py <<'PYEOF'
import os
from pathlib import Path
from flashinfer.aot import compile_and_package_modules, get_default_config
compile_and_package_modules(
    out_dir=Path(os.environ['FLASHINFER_AOT_OUT']),
    build_dir=Path(os.environ['FLASHINFER_AOT_BUILD']),
    project_root=Path(os.environ['FLASHINFER_SRC']),
    config=get_default_config(),
    verbose=True,
    skip_prebuilt=False,
)
PYEOF

    FLASHINFER_SRC=/home/ubuntu/src \
    FLASHINFER_AOT_OUT=/home/ubuntu/aot_out \
    FLASHINFER_AOT_BUILD=/home/ubuntu/aot_build \
    FLASHINFER_CUDA_ARCH_LIST=12.0 \
    MAX_JOBS=8 \
        /home/ubuntu/.local/share/uv/tools/vllm/bin/python /home/ubuntu/run_aot.py
"

echo "==> Installing AOT cache into the wheel's data/aot directory..."
# JitSpec.aot_path resolves to <wheel root>/data/aot/<name>/<name>.so when
# the flashinfer-jit-cache package is not installed, so dropping aot_out
# in place is all the runtime needs to skip JIT.
incus exec "$BUILDER" -- sudo -u ubuntu bash -euxc "
    WHEEL=\$(/home/ubuntu/.local/share/uv/tools/vllm/bin/python -c \
        'import flashinfer, pathlib; print(pathlib.Path(flashinfer.__file__).parent)')
    AOT_DST=\$WHEEL/data/aot
    rm -rf \$AOT_DST
    mv /home/ubuntu/aot_out \$AOT_DST
    echo \"AOT modules installed: \$(ls \$AOT_DST | wc -l) (\$(du -sh \$AOT_DST | cut -f1))\"
"

echo "==> Cleaning up the build tree before publish..."
incus exec "$BUILDER" -- bash -euxc "
    rm -rf /home/ubuntu/src /home/ubuntu/aot_build /home/ubuntu/run_aot.py
    apt-get clean
    rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*
"

echo "==> Stopping and publishing image..."
incus stop "$BUILDER"
# `incus publish --alias` fails if the alias is already taken (no
# overwrite flag), so on --force we drop it first. The previous image
# fingerprint is left behind, garbage-collected by `incus image flush`
# or naturally when nothing references it.
incus image alias delete "$ALIAS" 2>/dev/null || true
incus publish "$BUILDER" --alias "$ALIAS" \
    --compression zstd \
    description="ubuntu-cuda + vLLM ${VLLM_VERSION} + FlashInfer ${FLASHINFER_VERSION} AOT cache"

echo "==> Done. Image '$ALIAS' is ready."
