#!/bin/bash
# Build the 'ubuntu-rocm' Incus container image: Ubuntu 24.04 with ROCm
# HIP runtime + rocminfo/rocm-smi preinstalled. Targets AMD container
# hosts (c1/c2 — Strix Halo).
#
# The container is *unprivileged*; the host's /dev/kfd and
# /dev/dri/renderD128 are bind-mounted into it by the gpu-ct profile
# (gid 992, 'render' on the host). The profile maps host gid 992 to
# container gid 992 via raw.idmap, and this image preallocates a 'render'
# group at that gid and adds the default ubuntu user to render+video so
# the devices are accessible without sudo.
#
# ROCm version pin is in install-incus.yml (rocm_version). Currently
# ROCm 7.x in container vs ROCm 6.4.x on host; the amdkfd ioctl ABI is
# back-compatible so the userspace HIP runtime + the host kernel module
# interoperate. Bump to match the host if you hit ABI surprises.
#
# Generated by Ansible (install-incus.yml).
set -euo pipefail

ALIAS="ubuntu-rocm"
BUILDER="rocm-image-builder"
BASE="images:ubuntu/24.04"
ROCM_VERSION="{{ rocm_version }}"
RENDER_GID={{ incus_render_gid }}

if [[ "${1:-}" != "--force" ]] && incus image alias list --format csv | grep -q "^${ALIAS},"; then
    echo "Image '$ALIAS' already exists. Pass --force to rebuild."
    exit 0
fi

cleanup() { incus delete --force "$BUILDER" 2>/dev/null || true; }
trap cleanup EXIT

incus delete --force "$BUILDER" 2>/dev/null || true

echo "==> Launching builder container..."
incus launch "$BASE" "$BUILDER" \
    -c limits.cpu=4 -c limits.memory=8GiB \
    -d root,size=16GiB

echo "==> Waiting for agent / cloud-init..."
for _ in $(seq 1 60); do
    incus exec "$BUILDER" -- true 2>/dev/null && break
    sleep 3
done
incus exec "$BUILDER" -- cloud-init status --wait 2>/dev/null || true
# Wait for any in-flight apt from cloud-init to finish before our own apt runs.
for _ in $(seq 1 120); do
    incus exec "$BUILDER" -- bash -c \
        'pgrep -x apt-get >/dev/null || pgrep -x dpkg >/dev/null' || break
    sleep 3
done

echo "==> Installing ROCm ${ROCM_VERSION}..."
incus exec "$BUILDER" -- bash -euxc "
    export DEBIAN_FRONTEND=noninteractive

    # Pre-create the 'render' group at the host's render gid and add the
    # default cloud-image user to render+video. Combined with the
    # gpu-ct profile's raw.idmap, this makes the bind-mounted /dev/kfd
    # and /dev/dri/renderD128 usable without sudo.
    #
    # The upstream cloud image may already have a system group at the
    # target gid (e.g. systemd-coredump, _ssh). Bump that out of the way
    # to a free gid >= 2000 so we can claim it for render.
    clash=\$(getent group ${RENDER_GID} | cut -d: -f1 || true)
    if [ -n \"\$clash\" ] && [ \"\$clash\" != render ]; then
        free=2000
        while getent group \$free >/dev/null; do free=\$((free+1)); done
        echo \"Moving group \$clash from ${RENDER_GID} to \$free\"
        groupmod -g \$free \"\$clash\"
    fi
    if getent group render >/dev/null; then
        groupmod -g ${RENDER_GID} render
    else
        groupadd -g ${RENDER_GID} render
    fi
    usermod -aG render,video ubuntu

    apt-get update
    apt-get install -y --no-install-recommends ca-certificates curl gnupg
    install -d -m 0755 /etc/apt/keyrings
    curl -fsSL https://repo.radeon.com/rocm/rocm.gpg.key \
        | gpg --dearmor > /etc/apt/keyrings/rocm.gpg
    # 'noble' = Ubuntu 24.04 codename. The ROCm repo path /apt/<ver>
    # pins the userspace; the host kernel's amdgpu is independent.
    printf 'deb [arch=amd64 signed-by=/etc/apt/keyrings/rocm.gpg] %s noble main\n' \
        \"https://repo.radeon.com/rocm/apt/${ROCM_VERSION}\" \
        > /etc/apt/sources.list.d/rocm.list
    # AMD recommends pinning the rocm/amdgpu archives above the distro:
    cat > /etc/apt/preferences.d/rocm-pin-600 <<'EOF'
Package: *
Pin: origin \"repo.radeon.com\"
Pin-Priority: 600
EOF
    apt-get update
    # rocm-hip-runtime: HIP runtime + clang front-end + libs.
    # rocminfo / rocm-smi-lib: minimal sanity-check tooling.
    apt-get install -y --no-install-recommends \
        rocm-hip-runtime rocminfo rocm-smi-lib
    apt-get clean
    rm -rf /var/lib/apt/lists/*
"

echo "==> Stopping and publishing image..."
incus stop "$BUILDER"
incus image alias delete "$ALIAS" 2>/dev/null || true
incus publish "$BUILDER" --alias "$ALIAS" \
    --compression zstd \
    description="Ubuntu 24.04 + ROCm ${ROCM_VERSION} (HIP runtime, rocminfo, rocm-smi)"

echo "==> Done. Image '$ALIAS' is ready."
