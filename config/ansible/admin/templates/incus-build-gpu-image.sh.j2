#!/bin/bash
# Build the 'ubuntu-cuda' Incus VM image: Ubuntu 24.04 with the NVIDIA
# open kernel modules, CUDA toolkit and container toolkit preinstalled.
# Generated by Ansible (install-incus.yml).
set -euo pipefail

ALIAS="ubuntu-cuda"
BUILDER="cuda-image-builder"
BASE="images:ubuntu/24.04/cloud"
CUDA_VERSION="{{ cuda_version }}"

if [[ "${1:-}" != "--force" ]] && incus image alias list --format csv | grep -q "^${ALIAS},"; then
    echo "Image '$ALIAS' already exists. Pass --force to rebuild."
    exit 0
fi

cleanup() { incus delete --force "$BUILDER" 2>/dev/null || true; }
trap cleanup EXIT

incus delete --force "$BUILDER" 2>/dev/null || true

echo "==> Launching builder VM..."
incus launch "$BASE" "$BUILDER" --vm \
    -c limits.cpu=8 -c limits.memory=16GiB \
    -d root,size=40GiB

echo "==> Waiting for guest agent..."
for _ in $(seq 1 60); do
    incus exec "$BUILDER" -- true 2>/dev/null && break
    sleep 5
done
incus exec "$BUILDER" -- cloud-init status --wait || true

echo "==> Installing NVIDIA driver and CUDA in guest..."
incus exec "$BUILDER" -- bash -euxc "
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y build-essential dkms linux-headers-\$(uname -r) \
        pkg-config libglvnd-dev curl openssh-server \
        python3-dev ninja-build cmake
    curl -fsSL -o /tmp/cuda-keyring.deb \
        https://developer.download.nvidia.com/compute/cuda/repos/ubuntu2404/x86_64/cuda-keyring_1.1-1_all.deb
    apt-get install -y /tmp/cuda-keyring.deb
    rm -f /tmp/cuda-keyring.deb
    apt-get update
    apt-get install -y cuda-toolkit-${CUDA_VERSION} nvidia-open nvidia-container-toolkit
    printf 'export PATH=/usr/local/cuda/bin:\$PATH\nexport LD_LIBRARY_PATH=/usr/local/cuda/lib64:\$LD_LIBRARY_PATH\n' \
        > /etc/profile.d/cuda.sh
    apt-get clean
"

echo "==> Stopping and publishing image..."
incus stop "$BUILDER"
incus publish "$BUILDER" --alias "$ALIAS" \
    --compression zstd \
    description="Ubuntu 24.04 + NVIDIA open driver + CUDA ${CUDA_VERSION}"

echo "==> Done. Image '$ALIAS' is ready."
