# rathole server configuration
[server]
bind_addr = "0.0.0.0:2333"
default_token = "{{ rathole_token | default('change_me_secret_token') }}"

[server.transport]
type = "tcp"

[server.transport.tcp]
nodelay = true
keepalive_secs = 20
keepalive_interval = 8

[server.services.http]
bind_addr = "0.0.0.0:80"
type = "tcp"

[server.services.https]
bind_addr = "0.0.0.0:443"
type = "tcp"

[server.services.ssh1]
bind_addr = "127.0.0.1:2201"
type = "tcp"

[server.services.ssh2]
bind_addr = "127.0.0.1:2202"
type = "tcp"

[server.services.ssh3]
bind_addr = "127.0.0.1:2203"
type = "tcp"

# VM-access bastions (one public port per Incus VM host). Each VM host
# runs its own bastion container on its own incusbr0 and registers a
# distinct service name so the tunnels do not collide on the rathole
# server. Reach VMs with: ssh -J jump@<this-host>:<port> user@<vm-name>
#
# Per-host service name is set via `vm_bastion_service` in host_vars (see
# admin/install-vm-bastion.yml).
[server.services.vm-bastion-nv2]
bind_addr = "0.0.0.0:2212"
type = "tcp"

[server.services.vm-bastion-nv3]
bind_addr = "0.0.0.0:2213"
type = "tcp"
