# Managed by Ansible — install-local-ai-proxy.yml
# See docs/local-ai-proxy.md for design notes.
listen: "{{ proxy_listen }}"
{% if use_etcd | default(false) | bool %}
etcd:
  prefix: "{{ etcd_prefix | default('/cluster/config/inference/models/') }}"
{% else %}
backend:
  url: "{{ backend_url }}"
{% endif %}
