#!/bin/bash
set -e

# etcd client config (endpoints + TLS certs) from the single source; set -a
# exports the ETCDCTL_* vars so etcdctl picks them up.
set -a; . /etc/ycluster/etcd-client.env 2>/dev/null || true; set +a

BACKUP_DIR="/rbd/user/backups"
ENCRYPTED_BACKUP_DIR="/rbd/user/backups/encrypted"
POSTGRES_BACKUP_DIR="$BACKUP_DIR/postgres"
QDRANT_BACKUP_DIR="$BACKUP_DIR/qdrant"
ETCD_BACKUP_DIR="$BACKUP_DIR/etcd"
RETENTION_DAYS=30
TIMESTAMP=$(date +%Y%m%d_%H%M%S)

# Logging function
log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1"
}

# Create backup directories
create_backup_dirs() {
    log "Creating backup directories..."
    mkdir -p "$POSTGRES_BACKUP_DIR"
    mkdir -p "$QDRANT_BACKUP_DIR"
    mkdir -p "$ETCD_BACKUP_DIR"
    mkdir -p "$ENCRYPTED_BACKUP_DIR/postgres"
    mkdir -p "$ENCRYPTED_BACKUP_DIR/qdrant"
    mkdir -p "$ENCRYPTED_BACKUP_DIR/etcd"
}

# Backup PostgreSQL
backup_postgres() {
    log "Starting PostgreSQL backup..."
    
    # Check if PostgreSQL is running
    if ! systemctl is-active --quiet postgresql@16-main; then
        log "PostgreSQL is not running, skipping backup"
        return 0
    fi
    
    local backup_file="$POSTGRES_BACKUP_DIR/postgres_${TIMESTAMP}.sql.gz"
    
    # Create database dump
    if sudo -u postgres pg_dumpall | gzip > "$backup_file"; then
        log "PostgreSQL backup completed: $backup_file"
        
        # Verify backup file
        if [ -s "$backup_file" ]; then
            log "PostgreSQL backup verified (size: $(du -h "$backup_file" | cut -f1))"
            
            # Encrypt backup
            local encrypted_file="$ENCRYPTED_BACKUP_DIR/postgres/${TIMESTAMP}.sql.gz.age"
            if encrypt_backup "$backup_file" "$encrypted_file"; then
                log "PostgreSQL backup encrypted successfully"
            else
                log "ERROR: PostgreSQL backup encryption failed"
                return 1
            fi
        else
            log "ERROR: PostgreSQL backup file is empty"
            rm -f "$backup_file"
            return 1
        fi
    else
        log "ERROR: PostgreSQL backup failed"
        rm -f "$backup_file"
        return 1
    fi
}

# Backup Qdrant
backup_qdrant() {
    log "Starting Qdrant backup..."
    
    # Check if Qdrant is running
    if ! systemctl is-active --quiet qdrant; then
        log "Qdrant is not running, skipping backup"
        return 0
    fi
    
    # Check if Qdrant is responding
    if ! curl -s http://localhost:6333/health >/dev/null 2>&1; then
        log "Qdrant is not responding, skipping backup"
        return 0
    fi
    
    local backup_file="$QDRANT_BACKUP_DIR/qdrant_${TIMESTAMP}.snapshot"
    
    # Create full database snapshot using Qdrant API
    log "Creating Qdrant snapshot via API..."
    local snapshot_response=$(curl -s -X POST "http://localhost:6333/snapshots" \
        -H "Content-Type: application/json" \
        -d '{}' || echo '{"status":"error"}')
    
    # Parse snapshot name from response
    local snapshot_name=$(echo "$snapshot_response" | jq -r '.result.name // empty' 2>/dev/null)
    
    if [ -z "$snapshot_name" ]; then
        log "ERROR: Failed to create Qdrant snapshot"
        log "Response: $snapshot_response"
        return 1
    fi
    
    log "Qdrant snapshot created: $snapshot_name"
    
    # Wait a moment for snapshot to be written
    sleep 2
    
    # Find the snapshot file in Qdrant's snapshots directory
    local qdrant_snapshot_dir="/rbd/user/qdrant/snapshots"
    local snapshot_file="$qdrant_snapshot_dir/$snapshot_name"
    
    if [ ! -f "$snapshot_file" ]; then
        log "ERROR: Snapshot file not found: $snapshot_file"
        return 1
    fi
    
    # Copy snapshot to backup directory
    if cp "$snapshot_file" "$backup_file"; then
        log "Qdrant backup completed: $backup_file"
        
        # Verify backup file
        if [ -s "$backup_file" ]; then
            log "Qdrant backup verified (size: $(du -h "$backup_file" | cut -f1))"
            
            # Encrypt backup
            local encrypted_file="$ENCRYPTED_BACKUP_DIR/qdrant/${TIMESTAMP}.snapshot.age"
            if encrypt_backup "$backup_file" "$encrypted_file"; then
                log "Qdrant backup encrypted successfully"
            else
                log "ERROR: Qdrant backup encryption failed"
                return 1
            fi
        else
            log "ERROR: Qdrant backup file is empty"
            rm -f "$backup_file"
            return 1
        fi
        
        # Clean up the original snapshot file to save space
        rm -f "$snapshot_file"
        log "Cleaned up original snapshot file"
        
    else
        log "ERROR: Failed to copy Qdrant snapshot"
        return 1
    fi
}

# Backup etcd
backup_etcd() {
    log "Starting etcd backup..."
    
    # Check if etcd is running
    if ! systemctl is-active --quiet etcd; then
        log "etcd is not running, skipping backup"
        return 0
    fi
    
    local backup_file="$ETCD_BACKUP_DIR/${TIMESTAMP}.db"

    # Create etcd snapshot. `etcdctl snapshot save` requires exactly one
    # endpoint, but the centralized client env (etcd-client.env) lists every
    # member -- try each in turn.
    local endpoints="${ETCDCTL_ENDPOINTS:-127.0.0.1:2379}"
    local snapshot_ok=1 ep
    for ep in ${endpoints//,/ }; do
        if ETCDCTL_ENDPOINTS="$ep" etcdctl snapshot save "$backup_file"; then
            snapshot_ok=0
            break
        fi
        log "WARNING: etcd snapshot from $ep failed, trying next endpoint"
    done
    if [ "$snapshot_ok" -eq 0 ]; then
        log "etcd backup completed: $backup_file"
        
        # Verify backup file
        if [ -s "$backup_file" ]; then
            log "etcd backup verified (size: $(du -h "$backup_file" | cut -f1))"
            
            # Verify snapshot integrity
            if etcdctl snapshot status "$backup_file" --write-out=json >/dev/null 2>&1; then
                log "etcd snapshot integrity verified"
                
                # Encrypt backup
                local encrypted_file="$ENCRYPTED_BACKUP_DIR/etcd/${TIMESTAMP}.db.age"
                if encrypt_backup "$backup_file" "$encrypted_file"; then
                    log "etcd backup encrypted successfully"
                else
                    log "ERROR: etcd backup encryption failed"
                    return 1
                fi
            else
                log "ERROR: etcd snapshot integrity check failed"
                rm -f "$backup_file"
                return 1
            fi
        else
            log "ERROR: etcd backup file is empty"
            rm -f "$backup_file"
            return 1
        fi
    else
        log "ERROR: etcd backup failed"
        rm -f "$backup_file"
        return 1
    fi
}

# Get backup encryption recipients from etcd
get_age_recipients() {
    local recipients_file="/tmp/age_recipients_${TIMESTAMP}"
    
    # Use ycluster CLI to get recipients
    if command -v ycluster >/dev/null 2>&1; then
        # Get recipients from etcd using JSON output and extract public keys
        ycluster backup recipients list --json 2>/dev/null | jq -r '.[].public_key // empty' 2>/dev/null | grep -v '^$' > "$recipients_file" 2>/dev/null || true
        
        if [ -s "$recipients_file" ]; then
            echo "$recipients_file"
            return 0
        fi
    fi

    rm -f "$recipients_file"
    return 1
}

# Get backup destinations from etcd
get_backup_destinations() {
    if command -v ycluster >/dev/null 2>&1; then
        # Get enabled destinations from etcd using JSON output
        ycluster backup destinations list --json 2>/dev/null | jq -r '.[] | select(.enabled == true) | .name + " " + .url' 2>/dev/null || true
    fi
}

# Sync encrypted backups to remote destinations
sync_backups() {
    log "Starting backup sync to remote destinations..."
    
    if [ ! -d "$ENCRYPTED_BACKUP_DIR" ]; then
        log "No encrypted backup directory found, nothing to sync"
        return 0
    fi
    
    local encrypted_count=$(find "$ENCRYPTED_BACKUP_DIR" -name "*.age" | wc -l)
    if [ $encrypted_count -eq 0 ]; then
        log "No encrypted backups found, nothing to sync"
        return 0
    fi
    
    # Get destinations from etcd
    local destinations=$(get_backup_destinations)
    if [ -z "$destinations" ]; then
        log "No enabled backup destinations configured"
        return 0
    fi
    
    local sync_failures=0
    local sync_successes=0
    local total_destinations=0
    
    # Process each destination
    while IFS= read -r destination_line; do
        if [ -z "$destination_line" ]; then
            continue
        fi
        
        total_destinations=$((total_destinations + 1))
        local dest_name=$(echo "$destination_line" | cut -d' ' -f1)
        local dest_url=$(echo "$destination_line" | cut -d' ' -f2-)
        
        log "Syncing to destination: $dest_name ($dest_url)"
        
        # Add trailing slash to source directory to sync contents
        local source_dir="${ENCRYPTED_BACKUP_DIR}/"
        
        if rsync -av --timeout=300 -e 'ssh -o StrictHostKeyChecking=accept-new' "$source_dir" "$dest_url" 2>&1 | while IFS= read -r line; do
            log "  rsync: $line"
        done; then
            log "Successfully synced to $dest_name"
            sync_successes=$((sync_successes + 1))
        else
            log "ERROR: Failed to sync to $dest_name"
            sync_failures=$((sync_failures + 1))
        fi
        
    done <<< "$destinations"
    
    log "Sync summary: $sync_successes/$total_destinations destinations successful"
    
    if [ $sync_failures -gt 0 ]; then
        log "ERROR: $sync_failures destination(s) failed"
        return 1
    else
        log "All destinations synced successfully"
        return 0
    fi
}

# Encrypt backup file with age
encrypt_backup() {
    local source_file="$1"
    local encrypted_file="$2"
    
    log "Encrypting backup: $(basename "$source_file")"
    
    # Get recipients
    local recipients_file
    if ! recipients_file=$(get_age_recipients); then
        log "WARNING: No age recipients found, skipping encryption"
        return 1
    fi
    
    local recipient_count=$(wc -l < "$recipients_file")
    if [ "$recipient_count" -eq 0 ]; then
        log "WARNING: No valid age recipients found, skipping encryption"
        rm -f "$recipients_file"
        return 1
    fi
    
    log "Encrypting for $recipient_count recipients"
    
    # Build age command with recipients
    local age_cmd="age"
    while IFS= read -r recipient; do
        if [ -n "$recipient" ]; then
            age_cmd="$age_cmd -r $recipient"
        fi
    done < "$recipients_file"
    
    # Encrypt the file
    if eval "$age_cmd" < "$source_file" > "$encrypted_file"; then
        log "Encryption completed: $(basename "$encrypted_file")"
        log "Encrypted file size: $(du -h "$encrypted_file" | cut -f1)"
        rm -f "$recipients_file"
        return 0
    else
        log "ERROR: Encryption failed"
        rm -f "$recipients_file" "$encrypted_file"
        return 1
    fi
}

# Clean old backups
cleanup_old_backups() {
    log "Cleaning up backups older than $RETENTION_DAYS days..."
    
    # Clean PostgreSQL backups
    if [ -d "$POSTGRES_BACKUP_DIR" ]; then
        find "$POSTGRES_BACKUP_DIR" -name "postgres_*.sql.gz" -mtime +$RETENTION_DAYS -delete
        local pg_count=$(find "$POSTGRES_BACKUP_DIR" -name "postgres_*.sql.gz" | wc -l)
        log "PostgreSQL backups remaining: $pg_count"
    fi
    
    # Clean Qdrant backups
    if [ -d "$QDRANT_BACKUP_DIR" ]; then
        find "$QDRANT_BACKUP_DIR" -name "qdrant_*.snapshot" -mtime +$RETENTION_DAYS -delete
        local qdrant_count=$(find "$QDRANT_BACKUP_DIR" -name "qdrant_*.snapshot" | wc -l)
        log "Qdrant backups remaining: $qdrant_count"
    fi
    
    # Clean etcd backups
    if [ -d "$ETCD_BACKUP_DIR" ]; then
        find "$ETCD_BACKUP_DIR" -name "*.db" -mtime +$RETENTION_DAYS -delete
        local etcd_count=$(find "$ETCD_BACKUP_DIR" -name "*.db" | wc -l)
        log "etcd backups remaining: $etcd_count"
    fi
    
    # Clean encrypted backups
    if [ -d "$ENCRYPTED_BACKUP_DIR" ]; then
        find "$ENCRYPTED_BACKUP_DIR" -name "*.age" -mtime +$RETENTION_DAYS -delete
        local encrypted_count=$(find "$ENCRYPTED_BACKUP_DIR" -name "*.age" | wc -l)
        log "Encrypted backups remaining: $encrypted_count"
    fi
}

# Show backup status
show_status() {
    log "=== Backup Status ==="
    
    if [ -d "$POSTGRES_BACKUP_DIR" ]; then
        local pg_count=$(find "$POSTGRES_BACKUP_DIR" -name "postgres_*.sql.gz" | wc -l)
        local pg_size=$(du -sh "$POSTGRES_BACKUP_DIR" 2>/dev/null | cut -f1 || echo "0")
        log "PostgreSQL backups: $pg_count files, $pg_size total"
        
        if [ $pg_count -gt 0 ]; then
            local latest_pg=$(find "$POSTGRES_BACKUP_DIR" -name "postgres_*.sql.gz" -printf '%T@ %p\n' | sort -n | tail -1 | cut -d' ' -f2-)
            local latest_pg_date=$(stat -c %y "$latest_pg" 2>/dev/null | cut -d' ' -f1,2 | cut -d'.' -f1 || echo "unknown")
            log "  Latest: $(basename "$latest_pg") ($latest_pg_date)"
        fi
    fi
    
    if [ -d "$QDRANT_BACKUP_DIR" ]; then
        local qdrant_count=$(find "$QDRANT_BACKUP_DIR" -name "qdrant_*.snapshot" | wc -l)
        local qdrant_size=$(du -sh "$QDRANT_BACKUP_DIR" 2>/dev/null | cut -f1 || echo "0")
        log "Qdrant backups: $qdrant_count files, $qdrant_size total"
        
        if [ $qdrant_count -gt 0 ]; then
            local latest_qdrant=$(find "$QDRANT_BACKUP_DIR" -name "qdrant_*.snapshot" -printf '%T@ %p\n' | sort -n | tail -1 | cut -d' ' -f2-)
            local latest_qdrant_date=$(stat -c %y "$latest_qdrant" 2>/dev/null | cut -d' ' -f1,2 | cut -d'.' -f1 || echo "unknown")
            log "  Latest: $(basename "$latest_qdrant") ($latest_qdrant_date)"
        fi
    fi
    
    if [ -d "$ETCD_BACKUP_DIR" ]; then
        local etcd_count=$(find "$ETCD_BACKUP_DIR" -name "*.db" | wc -l)
        local etcd_size=$(du -sh "$ETCD_BACKUP_DIR" 2>/dev/null | cut -f1 || echo "0")
        log "etcd backups: $etcd_count files, $etcd_size total"
        
        if [ $etcd_count -gt 0 ]; then
            local latest_etcd=$(find "$ETCD_BACKUP_DIR" -name "*.db" -printf '%T@ %p\n' | sort -n | tail -1 | cut -d' ' -f2-)
            local latest_etcd_date=$(stat -c %y "$latest_etcd" 2>/dev/null | cut -d' ' -f1,2 | cut -d'.' -f1 || echo "unknown")
            log "  Latest: $(basename "$latest_etcd") ($latest_etcd_date)"
        fi
    fi
    
    if [ -d "$ENCRYPTED_BACKUP_DIR" ]; then
        local encrypted_count=$(find "$ENCRYPTED_BACKUP_DIR" -name "*.age" | wc -l)
        local encrypted_size=$(du -sh "$ENCRYPTED_BACKUP_DIR" 2>/dev/null | cut -f1 || echo "0")
        log "Encrypted backups: $encrypted_count files, $encrypted_size total"
        
        if [ $encrypted_count -gt 0 ]; then
            # Show latest PostgreSQL encrypted backup
            local latest_pg_encrypted=$(find "$ENCRYPTED_BACKUP_DIR/postgres" -name "*.age" -printf '%T@ %p\n' 2>/dev/null | sort -n | tail -1 | cut -d' ' -f2-)
            if [ -n "$latest_pg_encrypted" ]; then
                local latest_pg_encrypted_date=$(stat -c %y "$latest_pg_encrypted" 2>/dev/null | cut -d' ' -f1,2 | cut -d'.' -f1 || echo "unknown")
                log "  Latest PostgreSQL: $(basename "$latest_pg_encrypted") ($latest_pg_encrypted_date)"
            fi
            
            # Show latest Qdrant encrypted backup
            local latest_qdrant_encrypted=$(find "$ENCRYPTED_BACKUP_DIR/qdrant" -name "*.age" -printf '%T@ %p\n' 2>/dev/null | sort -n | tail -1 | cut -d' ' -f2-)
            if [ -n "$latest_qdrant_encrypted" ]; then
                local latest_qdrant_encrypted_date=$(stat -c %y "$latest_qdrant_encrypted" 2>/dev/null | cut -d' ' -f1,2 | cut -d'.' -f1 || echo "unknown")
                log "  Latest Qdrant: $(basename "$latest_qdrant_encrypted") ($latest_qdrant_encrypted_date)"
            fi
            
            # Show latest etcd encrypted backup
            local latest_etcd_encrypted=$(find "$ENCRYPTED_BACKUP_DIR/etcd" -name "*.age" -printf '%T@ %p\n' 2>/dev/null | sort -n | tail -1 | cut -d' ' -f2-)
            if [ -n "$latest_etcd_encrypted" ]; then
                local latest_etcd_encrypted_date=$(stat -c %y "$latest_etcd_encrypted" 2>/dev/null | cut -d' ' -f1,2 | cut -d'.' -f1 || echo "unknown")
                log "  Latest etcd: $(basename "$latest_etcd_encrypted") ($latest_etcd_encrypted_date)"
            fi
        fi
    fi
    
    local total_size=$(du -sh "$BACKUP_DIR" 2>/dev/null | cut -f1 || echo "0")
    log "Total backup size: $total_size"
}

# ---------------------------------------------------------------------------
# Restore / verify-restore
#
# `restore` loads a backup back into the LIVE services (DESTRUCTIVE); etcd is a
# safe primitive (restore to a fresh data-dir, never auto-swap) since rebuilding
# a quorum is a coordinated multi-node runbook — see
# docs/operations/disaster-recovery.md.
#
# `verify-restore` is the nightly drill: decrypt the newest backup and load it
# into throwaway scratch instances, then emit node-exporter textfile metrics
# (alerts in monitoring/templates/ycluster-alerts.yml.j2). It never touches a
# live service.
# ---------------------------------------------------------------------------

RESTORE_IDENTITY="${RESTORE_IDENTITY:-/rbd/user/backups/.restore-identity/identity.age}"
METRICS_FILE="${METRICS_FILE:-/var/lib/prometheus/node-exporter/backup_restore.prom}"
QDRANT_STORAGE_DIR="/rbd/user/qdrant/storage"
ETCD_DATA_DIR="/var/lib/etcd"
PG_VERSION=16

# Newest encrypted backup for a component (postgres|qdrant|etcd), or empty.
latest_encrypted() {
    local component="$1"
    find "$ENCRYPTED_BACKUP_DIR/$component" -name '*.age' -printf '%T@ %p\n' 2>/dev/null \
        | sort -n | tail -1 | cut -d' ' -f2-
}

# Decrypt an .age file to stdout using the restore identity.
decrypt_stream() {
    local src="$1"
    if [ ! -f "$RESTORE_IDENTITY" ]; then
        log "ERROR: restore identity not found: $RESTORE_IDENTITY"
        log "       (run storage/setup-backup-verify.yml on the storage leader)"
        return 1
    fi
    age -d -i "$RESTORE_IDENTITY" "$src"
}

# Confirm a destructive action unless --yes was passed.
require_yes() {
    if [ "${ASSUME_YES:-0}" = "1" ]; then return 0; fi
    local reply
    read -r -p "About to $1. This is DESTRUCTIVE. Type 'yes' to continue: " reply
    [ "$reply" = "yes" ]
}

restore_postgres() {
    local enc="${1:-$(latest_encrypted postgres)}"
    if [ -z "$enc" ] || [ ! -f "$enc" ]; then
        log "ERROR: no PostgreSQL backup to restore ($enc)"; return 1
    fi
    if ! systemctl is-active --quiet postgresql@16-main; then
        log "ERROR: postgresql@16-main is not running; start it before restore"; return 1
    fi
    require_yes "restore PostgreSQL from $(basename "$enc") into the LIVE cluster" \
        || { log "Aborted"; return 1; }
    log "Restoring PostgreSQL from $enc ..."
    # pg_dumpall is a plain SQL script (roles + every database). ON_ERROR_STOP=0
    # tolerates benign "role already exists" notices when restoring onto a
    # cluster that already has the default roles.
    if decrypt_stream "$enc" | gunzip | sudo -u postgres psql -v ON_ERROR_STOP=0 -d postgres >/dev/null; then
        log "PostgreSQL restore complete"
    else
        log "ERROR: PostgreSQL restore failed"; return 1
    fi
}

restore_qdrant() {
    local enc="${1:-$(latest_encrypted qdrant)}"
    if [ -z "$enc" ] || [ ! -f "$enc" ]; then
        log "ERROR: no Qdrant backup to restore ($enc)"; return 1
    fi
    require_yes "restore Qdrant from $(basename "$enc") (replaces $QDRANT_STORAGE_DIR)" \
        || { log "Aborted"; return 1; }
    local tmp; tmp=$(mktemp /tmp/qdrant-restore.XXXXXX.snapshot)
    if ! decrypt_stream "$enc" > "$tmp"; then rm -f "$tmp"; return 1; fi
    if ! tar -tf "$tmp" >/dev/null 2>&1; then
        log "ERROR: decrypted Qdrant snapshot is not a valid archive"; rm -f "$tmp"; return 1
    fi
    log "Stopping qdrant ..."
    systemctl stop qdrant || true
    # Keep the old storage aside for rollback rather than deleting it.
    local aside="${QDRANT_STORAGE_DIR}.pre-restore.${TIMESTAMP}"
    if [ -d "$QDRANT_STORAGE_DIR" ]; then mv "$QDRANT_STORAGE_DIR" "$aside"; fi
    mkdir -p "$QDRANT_STORAGE_DIR"
    # Full-storage snapshots (POST /snapshots) are a tar of the storage dir.
    # NB: verify the extracted layout against the running qdrant version on first
    # use (see disaster-recovery.md) — the old storage is preserved at $aside.
    tar -xf "$tmp" -C "$QDRANT_STORAGE_DIR"
    rm -f "$tmp"
    systemctl start qdrant
    log "Qdrant restored; previous storage kept at $aside (remove once verified)"
}

restore_etcd() {
    local enc="${1:-$(latest_encrypted etcd)}"
    if [ -z "$enc" ] || [ ! -f "$enc" ]; then
        log "ERROR: no etcd backup to restore ($enc)"; return 1
    fi
    if [ -z "${RESTORE_ETCD_DATADIR:-}" ]; then
        log "ERROR: restore etcd requires --data-dir <dir> (a fresh path)."
        log "       Rebuilding a quorum is a multi-node procedure: see"
        log "       docs/operations/disaster-recovery.md (etcd quorum loss)."
        return 1
    fi
    if [ -e "$RESTORE_ETCD_DATADIR" ]; then
        log "ERROR: $RESTORE_ETCD_DATADIR already exists; refusing to overwrite"; return 1
    fi
    local tmp; tmp=$(mktemp /tmp/etcd-restore.XXXXXX.db)
    if ! decrypt_stream "$enc" > "$tmp"; then rm -f "$tmp"; return 1; fi
    local name="${RESTORE_ETCD_NAME:-$(hostname -s)}"
    local args=(--data-dir "$RESTORE_ETCD_DATADIR")
    if [ -n "${RESTORE_ETCD_INITIAL_CLUSTER:-}" ]; then
        args+=(--name "$name" --initial-cluster "$RESTORE_ETCD_INITIAL_CLUSTER")
    fi
    if [ -n "${RESTORE_ETCD_PEER_URL:-}" ]; then
        args+=(--initial-advertise-peer-urls "$RESTORE_ETCD_PEER_URL")
    fi
    if etcdctl snapshot restore "$tmp" "${args[@]}"; then
        rm -f "$tmp"
        log "etcd snapshot restored to $RESTORE_ETCD_DATADIR (name=$name)"
        log "Next: stop etcd, replace $ETCD_DATA_DIR with it (chown etcd:etcd, mode 0700),"
        log "      then start etcd. Full procedure: docs/operations/disaster-recovery.md"
    else
        log "ERROR: etcd snapshot restore failed"; rm -f "$tmp"; return 1
    fi
}

verify_restore_postgres() {
    local enc; enc=$(latest_encrypted postgres)
    if [ -z "$enc" ]; then log "verify postgres: no backup found (skipped)"; return 2; fi
    local cluster="verifyrestore" port=5433 rc=0
    # Drop any leftover scratch cluster from a prior aborted run.
    if pg_lsclusters -h 2>/dev/null | awk '{print $1" "$2}' | grep -qx "$PG_VERSION $cluster"; then
        pg_dropcluster --stop "$PG_VERSION" "$cluster" >/dev/null 2>&1 || true
    fi
    if ! pg_createcluster "$PG_VERSION" "$cluster" -p "$port" >/dev/null 2>&1; then
        log "verify postgres: could not create scratch cluster"; return 1
    fi
    if ! pg_ctlcluster "$PG_VERSION" "$cluster" start >/dev/null 2>&1; then
        log "verify postgres: scratch cluster failed to start"
        pg_dropcluster --stop "$PG_VERSION" "$cluster" >/dev/null 2>&1 || true
        return 1
    fi
    if decrypt_stream "$enc" | gunzip | sudo -u postgres psql -p "$port" -d postgres -v ON_ERROR_STOP=0 >/dev/null 2>&1; then
        local dbs
        dbs=$(sudo -u postgres psql -p "$port" -tAc \
            "SELECT count(*) FROM pg_database WHERE datname NOT IN ('template0','template1','postgres');" 2>/dev/null) || dbs=0
        if [ "${dbs:-0}" -ge 1 ]; then
            log "verify postgres: dump loaded cleanly ($dbs user databases)"
        else
            log "verify postgres: dump loaded but no user databases found"; rc=1
        fi
    else
        log "verify postgres: psql load failed"; rc=1
    fi
    pg_dropcluster --stop "$PG_VERSION" "$cluster" >/dev/null 2>&1 || true
    return $rc
}

verify_restore_qdrant() {
    local enc; enc=$(latest_encrypted qdrant)
    if [ -z "$enc" ]; then log "verify qdrant: no backup found (skipped)"; return 2; fi
    # Shallow check: decrypt + archive integrity. A deep load into a temp qdrant
    # instance is a documented follow-up (disaster-recovery.md).
    local tmp rc=0; tmp=$(mktemp /tmp/verify-qdrant.XXXXXX.snapshot)
    if decrypt_stream "$enc" > "$tmp" && tar -tf "$tmp" >/dev/null 2>&1; then
        log "verify qdrant: snapshot decrypts and is a valid archive (shallow check)"
    else
        log "verify qdrant: FAILED"; rc=1
    fi
    rm -f "$tmp"
    return $rc
}

verify_restore_etcd() {
    local enc; enc=$(latest_encrypted etcd)
    if [ -z "$enc" ]; then log "verify etcd: no backup found (skipped)"; return 2; fi
    local tmp rc=0; tmp=$(mktemp -d /tmp/verify-etcd.XXXXXX)
    if decrypt_stream "$enc" > "$tmp/snap.db" \
        && etcdctl snapshot status "$tmp/snap.db" --write-out=json >/dev/null 2>&1 \
        && etcdctl snapshot restore "$tmp/snap.db" --data-dir "$tmp/data" >/dev/null 2>&1 \
        && [ -d "$tmp/data/member" ]; then
        log "verify etcd: snapshot restores to a valid data dir"
    else
        log "verify etcd: FAILED"; rc=1
    fi
    rm -rf "$tmp"
    return $rc
}

# Emit node-exporter textfile metrics for the verify-restore outcome + backup
# freshness. Rendering/scanning logic is in ycluster.utils.backup_status (unit
# tested); this just hands it the per-component result tokens (1|0|skip).
emit_verify_metrics() {
    local pg="$1" qd="$2" et="$3"
    local dir; dir=$(dirname "$METRICS_FILE")
    if [ ! -d "$dir" ]; then
        log "verify-restore: metrics dir $dir absent, skipping metric emission"
        return 0
    fi
    python3 -m ycluster.utils.backup_status \
        --encrypted-dir "$ENCRYPTED_BACKUP_DIR" \
        --out "$METRICS_FILE" \
        --result postgres="$pg" --result qdrant="$qd" --result etcd="$et" \
        || log "verify-restore: metric emission failed"
}

# Map a verify_restore_* return code to a metric token: 0->ok(1), 2->skip, else
# fail(0). Only a real failure (a present backup that did not load) fails the
# drill; an absent backup is skipped, not a failure.
verify_token() { case "$1" in 0) echo 1 ;; 2) echo skip ;; *) echo 0 ;; esac; }

verify_restore() {
    log "=== verify-restore drill ==="
    # `&& rc=0 || rc=$?` (not `cmd; rc=$?`) so set -e doesn't abort on a
    # non-zero return (fail=1 or skip=2) before we capture the code.
    local pg_rc qd_rc et_rc
    verify_restore_postgres && pg_rc=0 || pg_rc=$?
    verify_restore_qdrant   && qd_rc=0 || qd_rc=$?
    verify_restore_etcd     && et_rc=0 || et_rc=$?
    emit_verify_metrics "$(verify_token $pg_rc)" "$(verify_token $qd_rc)" "$(verify_token $et_rc)"
    if [ "$pg_rc" -ne 1 ] && [ "$qd_rc" -ne 1 ] && [ "$et_rc" -ne 1 ]; then
        log "verify-restore: no failures (postgres=$pg_rc qdrant=$qd_rc etcd=$et_rc; rc 0=ok 2=skip)"
        return 0
    fi
    log "verify-restore: FAILURES (postgres=$pg_rc qdrant=$qd_rc etcd=$et_rc; rc 1=fail)"
    return 1
}

# Check if this node is the storage leader
check_storage_leader() {
    # Check if user RBD is mounted (only storage leader should have this)
    if ! mountpoint -q "/rbd/user"; then
        log "User RBD not mounted, not storage leader, skipping backup"
        exit 0
    fi
}

# Main function
main() {
    case "$1" in
        backup)
            local databases="${2:-all}"
            log "Starting database backup process for: $databases"
            check_storage_leader
            create_backup_dirs
            
            local postgres_result=0
            local qdrant_result=0
            local etcd_result=0
            
            case "$databases" in
                postgres|postgresql)
                    backup_postgres || postgres_result=$?
                    qdrant_result=0  # Skip Qdrant, mark as success
                    etcd_result=0    # Skip etcd, mark as success
                    ;;
                qdrant)
                    backup_qdrant || qdrant_result=$?
                    postgres_result=0  # Skip PostgreSQL, mark as success
                    etcd_result=0      # Skip etcd, mark as success
                    ;;
                etcd)
                    backup_etcd || etcd_result=$?
                    postgres_result=0  # Skip PostgreSQL, mark as success
                    qdrant_result=0    # Skip Qdrant, mark as success
                    ;;
                all)
                    backup_postgres || postgres_result=$?
                    backup_qdrant || qdrant_result=$?
                    backup_etcd || etcd_result=$?
                    ;;
            esac
            
            cleanup_old_backups
            
            # Sync backups to remote destinations
            local sync_result=0
            if sync_backups; then
                log "Backup sync completed successfully"
            else
                log "Backup sync completed with errors"
                sync_result=1
            fi
            
            show_status
            
            if [ $postgres_result -eq 0 ] && [ $qdrant_result -eq 0 ] && [ $etcd_result -eq 0 ] && [ $sync_result -eq 0 ]; then
                log "Backup process completed successfully"
                exit 0
            else
                log "Backup process completed with errors"
                exit 1
            fi
            ;;
        sync)
            log "Starting backup sync process"
            check_storage_leader
            
            if sync_backups; then
                log "Backup sync completed successfully"
                exit 0
            else
                log "Backup sync completed with errors"
                exit 1
            fi
            ;;
        status)
            show_status
            ;;
        cleanup)
            log "Running cleanup only..."
            cleanup_old_backups
            show_status
            ;;
        restore)
            check_storage_leader
            shift
            local component="${1:-}"
            shift || true
            local restore_file=""
            while [ $# -gt 0 ]; do
                case "$1" in
                    --yes|-y) ASSUME_YES=1 ;;
                    --identity) RESTORE_IDENTITY="$2"; shift ;;
                    --data-dir) RESTORE_ETCD_DATADIR="$2"; shift ;;
                    --name) RESTORE_ETCD_NAME="$2"; shift ;;
                    --initial-cluster) RESTORE_ETCD_INITIAL_CLUSTER="$2"; shift ;;
                    --peer-url) RESTORE_ETCD_PEER_URL="$2"; shift ;;
                    -*) echo "Unknown restore option: $1"; exit 1 ;;
                    *) restore_file="$1" ;;
                esac
                shift
            done
            case "$component" in
                postgres|postgresql) restore_postgres "$restore_file" ;;
                qdrant)              restore_qdrant "$restore_file" ;;
                etcd)                restore_etcd "$restore_file" ;;
                *)
                    echo "Usage: $0 restore {postgres|qdrant|etcd} [file] [--yes] [--identity F]"
                    echo "  Restores the newest backup (or [file]) into the LIVE service. DESTRUCTIVE."
                    echo "  etcd: restores to a fresh dir only and needs --data-dir <dir>"
                    echo "        (+ optional --name/--initial-cluster/--peer-url for a cross-node rebuild);"
                    echo "        rebuilding a quorum is a runbook — see docs/operations/disaster-recovery.md"
                    exit 1
                    ;;
            esac
            ;;
        verify-restore)
            check_storage_leader
            create_backup_dirs
            verify_restore
            ;;
        *)
            echo "Usage: $0 {backup [postgres|qdrant|etcd|all]|restore <db> [file]|verify-restore|sync|status|cleanup}"
            echo "  backup [db]    - Create backups (default: all databases)"
            echo "    postgres     - Backup PostgreSQL only"
            echo "    qdrant       - Backup Qdrant only"
            echo "    etcd         - Backup etcd only"
            echo "    all          - Backup all databases (default)"
            echo "  restore <db>   - Restore newest backup into the LIVE service (DESTRUCTIVE; --yes to skip prompt)"
            echo "  verify-restore - Drill: load newest backups into scratch instances, emit metrics"
            echo "  sync           - Sync encrypted backups to remote destinations"
            echo "  status         - Show current backup status"
            echo "  cleanup        - Clean up old backups only"
            exit 1
            ;;
    esac
}

# Check if running as root
if [ "$EUID" -ne 0 ]; then
    echo "This script must be run as root"
    exit 1
fi


main "$@"
